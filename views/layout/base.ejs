<!DOCTYPE html>
<html lang="<%= language || 'en' %>" data-theme="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="csrf-token" content="<%= csrfToken || '' %>" />
  <link rel="icon" type="image/svg+xml" sizes="any" href="/images/logo/vicpods-icon-circle-dark.svg" />
  <link rel="shortcut icon" href="/images/logo/vicpods-icon-circle-dark.svg" />
  <title><%= title || 'VicPods' %></title>
  <meta name="description" content="<%= ((typeof metaDescription !== 'undefined') && metaDescription) || subtitle || 'VicPods helps creators go from podcast idea to ready-to-record episode.' %>" />
  <% if ((typeof canonicalUrl !== 'undefined') && canonicalUrl) { %>
    <link rel="canonical" href="<%= canonicalUrl %>" />
  <% } %>
  <% if ((typeof metaRobots !== 'undefined') && metaRobots) { %>
    <meta name="robots" content="<%= metaRobots %>" />
  <% } %>
  <meta property="og:title" content="<%= ((typeof ogTitle !== 'undefined') && ogTitle) || title || 'VicPods' %>" />
  <meta property="og:description" content="<%= ((typeof ogDescription !== 'undefined') && ogDescription) || (((typeof metaDescription !== 'undefined') && metaDescription)) || subtitle || 'VicPods helps creators go from podcast idea to ready-to-record episode.' %>" />
  <meta property="og:type" content="<%= ((typeof ogType !== 'undefined') && ogType) || 'website' %>" />
  <% if ((typeof canonicalUrl !== 'undefined') && canonicalUrl) { %>
    <meta property="og:url" content="<%= canonicalUrl %>" />
  <% } %>
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="<%= ((typeof ogTitle !== 'undefined') && ogTitle) || title || 'VicPods' %>" />
  <meta name="twitter:description" content="<%= ((typeof ogDescription !== 'undefined') && ogDescription) || (((typeof metaDescription !== 'undefined') && metaDescription)) || subtitle || 'VicPods helps creators go from podcast idea to ready-to-record episode.' %>" />
  <script>
    (function initTheme() {
      var serverDefault = '<%= (typeof currentUser !== "undefined" && currentUser && currentUser.themePreference) ? currentUser.themePreference : "dark" %>';
      var serverLanguage = '<%= language || "en" %>';
      var hasCurrentUser = <%= (typeof currentUser !== "undefined" && currentUser) ? 'true' : 'false' %>;
      try {
        var stored = localStorage.getItem('vicpods_theme');
        var theme = stored === 'light' || stored === 'dark' ? stored : serverDefault;
        document.documentElement.setAttribute('data-theme', theme);

        var storedLanguage = localStorage.getItem('vicpods_language');
        var language = serverLanguage;
        if (hasCurrentUser) {
          localStorage.setItem('vicpods_language', serverLanguage);
        } else if (storedLanguage === 'es' || storedLanguage === 'pt' || storedLanguage === 'en') {
          language = storedLanguage;
        }
        document.documentElement.setAttribute('lang', language);
      } catch (error) {
        document.documentElement.setAttribute('data-theme', serverDefault);
        document.documentElement.setAttribute('lang', serverLanguage);
      }
    }());
  </script>
  <script id="Cookiebot" src="https://consent.cookiebot.com/uc.js" data-cbid="7031f7cc-b0f4-4087-bc4b-de5aaaec95f7" data-blockingmode="auto" type="text/javascript"></script>
  <link rel="stylesheet" href="/stylesheets/style.css" />
</head>
<body class="<%= authPage ? 'auth-body' : (((typeof publicShell !== 'undefined') && publicShell) ? 'app-body app-body-public' : 'app-body') %>">
  <% if (authPage) { %>
    <main class="auth-shell <%= (typeof authShellClass !== 'undefined' && authShellClass) ? authShellClass : '' %>">
      <%- include('../partials/flash') %>
      <%- include('../' + view) %>
    </main>
  <% } else { %>
    <div class="app-shell <%= ((typeof publicShell !== 'undefined') && publicShell) ? 'app-shell-public' : '' %>">
      <% if (!((typeof publicShell !== 'undefined') && publicShell)) { %>
        <%- include('../partials/sidebar') %>
      <% } %>
      <div class="app-main">
        <%- include('../partials/topbar') %>
        <main class="content-wrap">
          <%- include('../partials/flash') %>
          <%- include('../' + view) %>
        </main>
        <%- include('../partials/footer') %>
      </div>
    </div>
    <%- include('../partials/help-chat') %>
    <div id="ai-loader-overlay" class="ai-loader-overlay" hidden aria-hidden="true">
      <div class="ai-loader-card" role="status" aria-live="polite" aria-atomic="true">
        <div class="ai-loader-logo-wrap" aria-hidden="true">
          <span class="ai-loader-ring"></span>
          <img
            src="/images/logo/vicpods-icon-circle-dark.svg"
            alt=""
            class="ai-loader-logo ai-loader-logo-dark"
            width="58"
            height="58"
          />
          <img
            src="/images/logo/vicpods-icon-circle-light.svg"
            alt=""
            class="ai-loader-logo ai-loader-logo-light"
            width="58"
            height="58"
          />
        </div>
        <h3>Chef AI is cooking your draft</h3>
        <p data-ai-loader-status>Analyzing your episode context and goals.</p>
        <div class="ai-loader-steps" aria-hidden="true">
          <span class="ai-loader-step is-active">Context</span>
          <span class="ai-loader-step">Tone</span>
          <span class="ai-loader-step">Draft</span>
        </div>
      </div>
    </div>

    <%- include('../partials/onboarding') %>
  <% } %>

  <script src="/javascripts/theme.js" defer></script>
  <script src="/javascripts/topbar.js" defer></script>
  <script src="/javascripts/csrf.js" defer></script>
  <script src="/javascripts/settings.js" defer></script>
  <script src="/javascripts/tone.js" defer></script>
  <script src="/javascripts/create.js" defer></script>
  <script src="/javascripts/ai-loading.js" defer></script>
  <script src="/javascripts/onboarding.js" defer></script>
  <script src="/javascripts/i18n-ui.js" defer></script>
  <script src="/javascripts/help-chat.js" defer></script>
  <script src="/javascripts/episode-tools.js" defer></script>
</body>
</html>
