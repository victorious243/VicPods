<% if (showOnboarding) { %>
  <div id="onboarding-overlay" class="onboarding-overlay" role="dialog" aria-modal="true" aria-labelledby="onboarding-title" aria-describedby="onboarding-description" hidden aria-hidden="true">
    <div class="onboarding-grid-glow" aria-hidden="true"></div>
    <div id="onboarding-backdrop" class="onboarding-backdrop" aria-hidden="true"></div>
    <div id="onboarding-highlight" class="onboarding-highlight" hidden aria-hidden="true">
      <span class="onboarding-highlight-pulse"></span>
    </div>

    <section class="onboarding-card" role="presentation" id="onboarding-card">
      <div class="onboarding-card-glow" aria-hidden="true"></div>
      <span class="onboarding-chip">Welcome to VicPods</span>
      <h3 id="onboarding-title"></h3>
      <p id="onboarding-description"></p>

      <div class="onboarding-progress">
        <span id="onboarding-step-counter"></span>
        <div class="onboarding-progress-track">
          <span id="onboarding-progress-fill" class="onboarding-progress-fill"></span>
        </div>
      </div>

      <div id="onboarding-links" class="onboarding-links" hidden></div>

      <div class="onboarding-actions">
        <button id="onboarding-skip" type="button" class="btn btn-ghost">Skip tour</button>
        <div class="inline-actions">
          <button id="onboarding-back" type="button" class="btn btn-ghost" hidden>Back</button>
          <button id="onboarding-next" type="button" class="btn btn-primary">Next</button>
        </div>
      </div>
    </section>
  </div>
<% } %>
