<footer class="site-footer">
  <div class="site-footer-copy">
    <strong>VicPods</strong>
    <p><%= t('footer.tagline', 'Ready-to-record podcast planning and launch prep.') %></p>
    <small>&copy; <%= new Date().getFullYear() %> VicPods. <%= t('footer.note', 'Built to help creators shape stronger episodes, show notes, and briefs before they record.') %></small>
  </div>

  <nav class="site-footer-links" aria-label="Footer">
    <a href="/about"><%= t('page.about.link', 'About VicPods') %></a>
    <a href="/help"><%= t('page.help.link', 'Help Center') %></a>
    <a href="/podcast-idea-generator">Podcast Idea Generator</a>
    <a href="/examples">Example Library</a>
    <a href="/terms"><%= t('footer.terms', 'Terms') %></a>
    <a href="/privacy-policy"><%= t('footer.privacy', 'Privacy Policy') %></a>
    <a href="/cookie-policy"><%= t('footer.cookies', 'Cookie Policy') %></a>
    <a href="/data-rights"><%= t('footer.dataRights', 'Data Rights') %></a>
    <% if (currentUser) { %>
      <a href="/studio"><%= t('nav.studio', 'Studio') %></a>
      <a href="/kitchen"><%= t('nav.kitchen', 'Workspace') %></a>
      <a href="/settings"><%= t('nav.settings', 'Settings') %></a>
    <% } else { %>
      <a href="/auth/login"><%= t('page.about.cta.guest.secondary', 'Sign in') %></a>
      <a href="/auth/register"><%= t('page.about.cta.guest.primary', 'Create account') %></a>
    <% } %>
  </nav>
</footer>
