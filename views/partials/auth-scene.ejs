<aside class="auth-scene">
  <div class="auth-scene-orb auth-scene-orb-primary" aria-hidden="true"></div>
  <div class="auth-scene-orb auth-scene-orb-secondary" aria-hidden="true"></div>

  <div class="auth-scene-copy">
    <span class="auth-kicker"><%= kicker %></span>
    <h2><%= heading %></h2>
    <p><%= body %></p>
  </div>

  <div class="auth-signal-cluster" aria-hidden="true">
    <span class="auth-signal-ring auth-signal-ring-outer"></span>
    <span class="auth-signal-ring auth-signal-ring-mid"></span>
    <span class="auth-signal-ring auth-signal-ring-inner"></span>
    <span class="auth-signal-core"></span>
  </div>

  <% if (featureChips && featureChips.length) { %>
    <div class="chip-wrap auth-chip-wrap">
      <% featureChips.forEach(function(feature) { %>
        <span class="chip auth-chip"><%= feature %></span>
      <% }) %>
    </div>
  <% } %>

  <% if (metricCards && metricCards.length) { %>
    <div class="auth-scene-metrics">
      <% metricCards.forEach(function(metric) { %>
        <article class="auth-scene-metric">
          <strong><%= metric.value %></strong>
          <span><%= metric.label %></span>
        </article>
      <% }) %>
    </div>
  <% } %>

  <% if (railItems && railItems.length) { %>
    <div class="auth-scene-rail">
      <% railItems.forEach(function(item, index) { %>
        <div class="auth-scene-rail-item">
          <span class="auth-scene-rail-index"><%= String(index + 1).padStart(2, '0') %></span>
          <div class="auth-scene-rail-copy">
            <strong><%= item.title %></strong>
            <span><%= item.body %></span>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</aside>
