<% const planLabels = { free: t('plan.free', 'Free'), pro: t('plan.pro', 'Pro'), premium: t('plan.premium', 'Premium') }; %>

<section class="card settings-nav-card">
  <div class="section-head">
    <h3>Settings</h3>
    <span class="mini-label"><%= planLabels[effectivePlan] || effectivePlan %> plan</span>
  </div>
  <div class="settings-tab-grid" id="onboarding-settings-tabs">
    <a class="settings-tab-card <%= selectedSection === 'profile' ? 'active-settings-tab' : '' %>" href="/settings?section=profile">
      <span class="settings-tab-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M20 21a8 8 0 0 0-16 0" />
          <circle cx="12" cy="7" r="4" />
        </svg>
      </span>
      <span class="settings-tab-text">
        <strong>Profile</strong>
        <small>Name, email, avatar</small>
      </span>
    </a>

    <a id="onboarding-settings-tab-appearance" class="settings-tab-card <%= selectedSection === 'appearance' ? 'active-settings-tab' : '' %>" href="/settings?section=appearance">
      <span class="settings-tab-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <path d="M12 3v2" />
          <path d="M12 19v2" />
          <path d="M4.93 4.93l1.41 1.41" />
          <path d="M17.66 17.66l1.41 1.41" />
          <path d="M3 12h2" />
          <path d="M19 12h2" />
          <path d="M4.93 19.07l1.41-1.41" />
          <path d="M17.66 6.34l1.41-1.41" />
          <circle cx="12" cy="12" r="4" />
        </svg>
      </span>
      <span class="settings-tab-text">
        <strong>Appearance</strong>
        <small>Dark and light mode</small>
      </span>
    </a>

    <a class="settings-tab-card <%= selectedSection === 'security' ? 'active-settings-tab' : '' %>" href="/settings?section=security">
      <span class="settings-tab-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="11" width="18" height="10" rx="2" />
          <path d="M7 11V8a5 5 0 0 1 10 0v3" />
        </svg>
      </span>
      <span class="settings-tab-text">
        <strong>Security</strong>
        <small>Password and account safety</small>
      </span>
    </a>

    <a class="settings-tab-card <%= selectedSection === 'billing' ? 'active-settings-tab' : '' %>" href="/settings?section=billing">
      <span class="settings-tab-icon" aria-hidden="true">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
          <rect x="2" y="5" width="20" height="14" rx="2" />
          <path d="M2 10h20" />
          <path d="M7 15h3" />
        </svg>
      </span>
      <span class="settings-tab-text">
        <strong>Billing</strong>
        <small>Plan, invoices, upgrades</small>
      </span>
    </a>
  </div>
</section>

<% if (selectedSection === 'profile') { %>
  <section class="split-grid settings-grid">
    <article class="card">
      <div class="section-head">
        <h3>Profile Details</h3>
      </div>
      <form method="POST" action="/settings/profile" class="form-grid" id="onboarding-settings-profile-form">
        <label>
          Full Name
          <input type="text" name="name" required maxlength="80" value="<%= currentUser.name %>" />
        </label>
        <label>
          Email
          <input type="email" name="email" required maxlength="160" value="<%= currentUser.email %>" />
        </label>
        <label>
          Avatar URL (optional)
          <input type="text" name="avatarUrl" maxlength="1000" value="<%= currentUser.avatarUrl || '' %>" placeholder="https://..." />
        </label>
        <button type="submit" class="btn btn-primary">Save Profile</button>
      </form>
    </article>

    <article class="card">
      <div class="section-head">
        <h3>Avatar Preview</h3>
      </div>
      <% const avatarName = (currentUser.name || currentUser.email || 'User').trim(); %>
      <% const avatarInitials = avatarName.split(/\s+/).filter(Boolean).slice(0, 2).map((part) => part[0].toUpperCase()).join('') || 'VP'; %>
      <div class="settings-avatar">
        <% if (currentUser.avatarUrl) { %>
          <img src="<%= currentUser.avatarUrl %>" alt="User avatar" />
        <% } else { %>
          <span><%= avatarInitials %></span>
        <% } %>
      </div>
      <p><strong><%= currentUser.name %></strong></p>
      <p class="mini-note"><%= currentUser.email %></p>
      <p class="mini-note">Every user has an avatar: custom image URL or automatic initials badge.</p>
      <form method="POST" action="/settings/onboarding/reset">
        <button class="btn btn-ghost" type="submit">Replay onboarding tour</button>
      </form>
    </article>
  </section>
<% } %>

<% if (selectedSection === 'appearance') { %>
  <section class="card">
    <div class="section-head">
      <h3>Theme Preferences</h3>
      <span class="mini-label">Dark + Light</span>
    </div>
    <form method="POST" action="/settings/appearance" class="form-grid" id="appearance-form">
      <label>
        Default Theme
        <select name="themePreference" id="theme-preference-select">
          <option value="dark" <%= (currentUser.themePreference || 'dark') === 'dark' ? 'selected' : '' %>><%= t('theme.dark', 'Dark') %></option>
          <option value="light" <%= currentUser.themePreference === 'light' ? 'selected' : '' %>><%= t('theme.light', 'Light') %></option>
        </select>
      </label>
      <label>
        <%= t('settings.language.label', 'App Language') %>
        <select name="languagePreference" id="language-preference-select">
          <% (languageOptions || []).forEach((option) => { %>
            <option value="<%= option.value %>" <%= (currentUser.languagePreference || 'en') === option.value ? 'selected' : '' %>><%= option.label %></option>
          <% }) %>
        </select>
      </label>
      <p class="mini-note"><%= t('settings.theme.note', 'Topbar toggle still works instantly. This sets your account default theme.') %></p>
      <p class="mini-note"><%= t('settings.language.note', 'UI labels and AI output will follow this language.') %></p>
      <button type="submit" class="btn btn-primary">Save Appearance</button>
    </form>
  </section>
<% } %>

<% if (selectedSection === 'security') { %>
  <section class="card">
    <div class="section-head">
      <h3>Change Password</h3>
      <span class="mini-label">Account Security</span>
    </div>
    <form method="POST" action="/settings/security/password" class="form-grid">
      <label>
        Current Password
        <input type="password" name="currentPassword" required minlength="8" autocomplete="current-password" />
      </label>
      <div class="two-col">
        <label>
          New Password
          <input type="password" name="newPassword" required minlength="8" autocomplete="new-password" />
        </label>
        <label>
          Confirm New Password
          <input type="password" name="confirmPassword" required minlength="8" autocomplete="new-password" />
        </label>
      </div>
      <button type="submit" class="btn btn-primary">Update Password</button>
    </form>
  </section>
<% } %>

<% if (selectedSection === 'billing') { %>
  <%
    const paidActive = (billing.planStatus === 'active' || billing.planStatus === 'trialing') && billing.effectivePlan !== 'free';
    const currentPlanLabel = planLabels[billing.effectivePlan] || billing.effectivePlan;
    const billingHeroTitle = paidActive
      ? `${currentPlanLabel} access is active`
      : billing.planStatus === 'past_due'
        ? 'Billing needs attention'
        : billing.effectivePlan === 'free'
          ? 'Upgrade into the premium workflow'
          : `${currentPlanLabel} access is syncing`;
    const billingHeroBody = paidActive
      ? 'Your account is unlocked for the current cycle. Use Billing to manage invoices, upgrades, and future renewal decisions.'
      : billing.planStatus === 'past_due'
        ? 'Stripe reported a billing issue. Update your payment details to restore paid access without losing momentum.'
        : billing.effectivePlan === 'free'
          ? 'Move beyond the starter workspace with stronger continuity controls, richer exports, and higher daily generation capacity.'
          : 'Your Stripe checkout completed, but the plan refresh is still being finalized. This page will reflect the paid tier as soon as sync completes.';
    const billingPlans = [
      {
        key: 'free',
        eyebrow: 'Starter',
        title: 'Free',
        price: pricing.free,
        summary: 'Clean core workspace for early planning.',
        note: 'Included for every account.',
        features: [
          'Core Studio + Workspace + Pantry access',
          '5 AI generations each day',
          'Release Readiness Score + Show Notes Pack',
          'Episode Brief TXT export',
        ],
      },
      {
        key: 'pro',
        eyebrow: 'Most popular',
        title: 'Pro',
        price: pricing.pro,
        summary: 'Sharper production flow for serious weekly shows.',
        note: `Launch price through ${pricing.foundingDeadlineLabel}. Planned standard price: ${pricing.proStandard}.`,
        features: [
          '50 AI generations each day',
          'Continuity refresh + stronger series planning',
          'Tone consistency scoring',
          'Episode Brief TXT + PDF exports',
        ],
      },
      {
        key: 'premium',
        eyebrow: 'Highest control',
        title: 'Premium',
        price: pricing.premium,
        summary: 'Full VicPods suite with maximum AI and export depth.',
        note: `Launch price through ${pricing.foundingDeadlineLabel}. Planned standard price: ${pricing.premiumStandard}.`,
        features: [
          'Unlimited AI generations',
          'Tone Fix + Voice Persona controls',
          'Highest continuity workflow access',
          'Episode Brief TXT + PDF + DOCX exports',
        ],
      },
    ];
  %>

  <section class="card billing-hero billing-hero-premium">
    <div class="billing-hero-copy">
      <span class="billing-kicker">Billing Control</span>
      <h3><%= billingHeroTitle %></h3>
      <p><%= billingHeroBody %></p>
      <div class="billing-chip-row">
        <span class="badge <%= billing.statusBadgeClass %>"><%= billing.planStatusLabel %></span>
        <span class="mini-label"><%= currentPlanLabel %> plan</span>
        <% if (billing.currentPeriodEndLabel && paidActive) { %>
          <span class="mini-label">through <%= billing.currentPeriodEndLabel %></span>
        <% } %>
        <% if (billing.storedPlan !== billing.effectivePlan) { %>
          <span class="mini-label">stored: <%= planLabels[billing.storedPlan] || billing.storedPlan %></span>
        <% } %>
      </div>
      <% if (billing.cancelAtPeriodEnd && billing.currentPeriodEndLabel) { %>
        <p class="flash flash-error">Your plan will end on <%= billing.currentPeriodEndLabel %> unless renewed.</p>
      <% } %>
      <% if (billing.planStatus === 'past_due') { %>
        <p class="flash flash-error">Payment is past due. Update billing details to reactivate paid access.</p>
      <% } %>
      <div class="inline-actions">
        <form method="POST" action="/billing/portal">
          <button class="btn btn-secondary" type="submit">Manage Billing</button>
        </form>
        <a href="/studio" class="btn btn-ghost">Open Studio</a>
      </div>
    </div>

    <aside class="billing-hero-panel">
      <div class="billing-stat-card">
        <span class="billing-panel-label">Current access</span>
        <strong><%= currentPlanLabel %></strong>
        <small><%= paidActive ? 'Premium tools are available right now.' : 'Upgrade when you are ready.' %></small>
      </div>
      <div class="billing-stat-card">
        <span class="billing-panel-label">Billing status</span>
        <strong><%= billing.planStatusLabel %></strong>
        <small><%= billing.currentPeriodStartLabel ? `Started ${billing.currentPeriodStartLabel}` : 'No paid cycle on record yet.' %></small>
      </div>
      <div class="billing-stat-card">
        <span class="billing-panel-label">Current window</span>
        <strong><%= billing.currentPeriodEndLabel || 'Not available yet' %></strong>
        <small><%= paidActive ? 'Managed by Stripe subscription dates.' : 'Will populate after activation.' %></small>
      </div>
    </aside>
  </section>

  <section class="card billing-launch-band">
    <div>
      <span class="billing-kicker">Founding Launch Pricing</span>
      <h3>Premium tools, launch-window pricing</h3>
      <p>Lock in March 2026 pricing while VicPods sharpens ready-to-record planning, release readiness, show notes, and export workflows.</p>
    </div>
    <span class="mini-label">through <%= pricing.foundingDeadlineLabel %></span>
  </section>

  <section class="card-grid plan-grid premium-plan-grid">
    <% billingPlans.forEach((plan) => { %>
      <% const planIsCurrent = billing.effectivePlan === plan.key && (plan.key === 'free' || paidActive); %>
      <% const planIsSyncing = billing.effectivePlan === plan.key && !planIsCurrent && plan.key !== 'free'; %>
      <article class="card plan-card premium-plan-card <%= planIsCurrent ? 'active-plan premium-plan-card-active' : '' %> <%= plan.key === 'pro' ? 'premium-plan-card-featured' : '' %>">
        <div class="premium-plan-card-top">
          <div>
            <span class="mini-label"><%= plan.eyebrow %></span>
            <h3><%= plan.title %></h3>
          </div>
          <% if (planIsCurrent) { %>
            <span class="badge badge-ready">Current access</span>
          <% } else if (planIsSyncing) { %>
            <span class="badge badge-draft">Syncing</span>
          <% } else if (plan.key === 'pro') { %>
            <span class="badge badge-planned">Best value</span>
          <% } else if (plan.key === 'premium') { %>
            <span class="badge badge-served">Elite</span>
          <% } %>
        </div>

        <p class="price premium-price"><%= plan.price %></p>
        <p class="premium-plan-tagline"><%= plan.summary %></p>
        <p class="mini-note"><%= plan.note %></p>

        <ul class="premium-plan-feature-list">
          <% plan.features.forEach((feature) => { %>
            <li>
              <span class="premium-feature-dot" aria-hidden="true"></span>
              <span><%= feature %></span>
            </li>
          <% }) %>
        </ul>

        <% if (plan.key === 'free') { %>
          <button class="btn btn-secondary" disabled><%= billing.effectivePlan === 'free' ? 'Current Access' : 'Always Available' %></button>
        <% } else if (planIsCurrent) { %>
          <button class="btn btn-secondary" disabled>Current Access</button>
        <% } else { %>
          <form method="POST" action="/billing/checkout">
            <input type="hidden" name="plan" value="<%= plan.key %>" />
            <button class="btn btn-primary" type="submit">Upgrade to <%= plan.title %></button>
          </form>
        <% } %>
      </article>
    <% }) %>
  </section>
<% } %>
