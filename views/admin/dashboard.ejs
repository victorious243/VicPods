<section class="card">
  <div class="section-head">
    <h3><%= t('admin.section.commandCenter', 'Secret Admin Command Center') %></h3>
    <span class="mini-label"><%= t('admin.section.restricted', 'Admin only') %></span>
  </div>
  <p class="mini-note">
    <strong><%= t('admin.meta.pathLabel', 'Dashboard path') %>:</strong>
    <code><%= dashboardPath %></code>
  </p>
  <p class="mini-note">
    <strong><%= t('admin.meta.keyLabel', 'Secret key protection') %>:</strong>
    <%= secretKeyEnabled ? t('admin.meta.enabled', 'Enabled') : t('admin.meta.devFallback', 'Disabled (development fallback)') %>
  </p>
</section>

<section class="card-grid stats-grid">
  <article class="card stat-card">
    <p><%= t('admin.metric.totalUsers', 'Total users') %></p>
    <h3><%= metrics.totalUsers %></h3>
    <span class="mini-note">+<%= metrics.usersLast24h %> / 24h</span>
  </article>
  <article class="card stat-card">
    <p><%= t('admin.metric.subscribers', 'Subscribers (Pro/Premium)') %></p>
    <h3><%= metrics.totalSubscribers %></h3>
    <span class="mini-note"><%= t('admin.metric.activePaid', 'Active paid') %>: <%= metrics.activePaidUsers %></span>
  </article>
  <article class="card stat-card">
    <p><%= t('admin.metric.paymentRisk', 'Payment risk users') %></p>
    <h3><%= metrics.paymentRiskUsers %></h3>
    <span class="mini-note"><%= t('admin.metric.planHealth', 'Past due or unpaid') %></span>
  </article>
  <article class="card stat-card">
    <p><%= t('admin.metric.aiCalls', 'AI calls today') %></p>
    <h3><%= metrics.aiCallsToday %></h3>
    <span class="mini-note"><%= t('admin.metric.aiActive', 'Active AI users today') %>: <%= metrics.aiActiveUsersToday %></span>
  </article>
</section>

<section class="card-grid stats-grid">
  <article class="card stat-card">
    <p>Page views (24h)</p>
    <h3><%= metrics.pageViews24h %></h3>
    <span class="mini-note">Unique visitors / 7d: <%= metrics.uniqueVisitors7d %></span>
  </article>
  <article class="card stat-card">
    <p>Completed signups (7d)</p>
    <h3><%= metrics.signupsCompleted7d %></h3>
    <span class="mini-note">Signup starts / 7d: <%= metrics.signupsStarted7d %></span>
  </article>
  <article class="card stat-card">
    <p>Successful logins (7d)</p>
    <h3><%= metrics.logins7d %></h3>
    <span class="mini-note">Tracked across web, API, and Google auth</span>
  </article>
  <article class="card stat-card">
    <p>Episode previews (7d)</p>
    <h3><%= metrics.publicEpisodePreviews7d %></h3>
    <span class="mini-note">Podcast idea runs / 7d: <%= metrics.publicPodcastIdeas7d %></span>
  </article>
  <article class="card stat-card">
    <p>Preview leads saved (7d)</p>
    <h3><%= metrics.publicPreviewSaves7d %></h3>
    <span class="mini-note">Total lead emails: <%= metrics.totalPreviewLeads %></span>
  </article>
  <article class="card stat-card">
    <p>Drafts generated (7d)</p>
    <h3><%= metrics.episodeDrafts7d %></h3>
    <span class="mini-note">Episodes created / 7d: <%= metrics.episodesCreated7d %></span>
  </article>
  <article class="card stat-card">
    <p>Checkout starts (7d)</p>
    <h3><%= metrics.checkoutStarts7d %></h3>
    <span class="mini-note">Completed billing returns / 7d: <%= metrics.checkoutCompleted7d %></span>
  </article>
  <article class="card stat-card">
    <p><%= t('admin.metric.newUsers7d', 'New users (7d)') %></p>
    <h3><%= metrics.usersLast7d %></h3>
    <span class="mini-note"><%= t('admin.metric.newUsers30d', 'New users (30d)') %>: <%= metrics.usersLast30d %></span>
  </article>
  <article class="card stat-card">
    <p><%= t('admin.metric.totalSeries', 'Total series') %></p>
    <h3><%= metrics.totalSeries %></h3>
    <span class="mini-note">+<%= metrics.seriesLast7d %> / 7d</span>
  </article>
  <article class="card stat-card">
    <p><%= t('admin.metric.totalEpisodes', 'Total episodes') %></p>
    <h3><%= metrics.totalEpisodes %></h3>
    <span class="mini-note">+<%= metrics.episodesLast7d %> / 7d · +<%= metrics.episodesLast24h %> / 24h</span>
  </article>
  <article class="card stat-card">
    <p><%= t('admin.metric.totalIdeas', 'Pantry ideas') %></p>
    <h3><%= metrics.totalIdeas %></h3>
    <span class="mini-note">+<%= metrics.ideasLast7d %> / 7d</span>
  </article>
</section>

<section class="card">
  <div class="section-head">
    <h3>Public preview leads</h3>
    <span class="mini-label"><%= metrics.totalPreviewLeads %> saved emails</span>
  </div>
  <% if (!recentPreviewLeads.length) { %>
    <p class="empty-state">No public preview leads captured yet.</p>
  <% } else { %>
    <div class="admin-preview-lead-summary">
      <span class="mini-label">Episode preview leads: <%= breakdown.previewLeads.episode_preview %></span>
      <span class="mini-label">Podcast idea leads: <%= breakdown.previewLeads.podcast_ideas %></span>
      <span class="mini-label">Saved in the last 7 days: <%= metrics.recentPreviewLeads7d %></span>
      <span class="mini-label">Preview exports / 7d: <%= metrics.publicPreviewExports7d %></span>
      <span class="mini-label">Billing views / 7d: <%= metrics.billingViews7d %></span>
    </div>
    <div class="list-stack">
      <% recentPreviewLeads.forEach((lead) => { %>
        <div class="list-item admin-preview-lead-item">
          <div>
            <h4><%= lead.email %></h4>
            <p><%= lead.source === 'podcast_ideas' ? 'Podcast idea generator' : 'Idea to episode preview' %></p>
            <% if (lead.sourceInput) { %>
              <p class="mini-note"><%= lead.sourceInput %></p>
            <% } %>
            <p class="mini-note">
              Saved: <%= lead.lastSavedAt ? new Date(lead.lastSavedAt).toLocaleString() : 'Not recorded' %>
              <% if (lead.lastSentAt) { %>
                · emailed: <%= new Date(lead.lastSentAt).toLocaleString() %>
              <% } %>
            </p>
          </div>
          <div class="inline-actions admin-signup-meta">
            <span class="mini-label"><%= lead.source %></span>
            <span class="mini-label">captures: <%= lead.captureCount || 0 %></span>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</section>

<section class="card">
  <div class="section-head">
    <h3>Recent VicPods activity</h3>
    <span class="mini-label">Visitors + auth events</span>
  </div>
  <% if (!recentActivityEvents.length) { %>
    <p class="empty-state">No visitor activity recorded yet.</p>
  <% } else { %>
    <div class="list-stack">
      <% recentActivityEvents.forEach((event) => { %>
        <% const eventLabel = String(event.eventType || '').replace(/_/g, ' '); %>
        <% const actorLabel = event.userEmail || (event.visitorId ? `Visitor ${String(event.visitorId).slice(0, 8)}` : 'Anonymous visitor'); %>
        <div class="list-item">
          <div>
            <h4><%= actorLabel %></h4>
            <p><%= event.requestPath %> · <%= event.authProvider === 'unknown' ? 'visitor' : event.authProvider %></p>
            <p class="mini-note">
              <%= new Date(event.createdAt).toLocaleString() %>
              <% if (event.statusCode) { %>
                · status <%= event.statusCode %>
              <% } %>
            </p>
          </div>
          <span class="mini-label"><%= eventLabel %></span>
        </div>
      <% }) %>
    </div>
  <% } %>
</section>

<section class="card-grid stats-grid">
  <article class="card stat-card">
    <p>Admin link hits (24h)</p>
    <h3><%= metrics.adminAccessAttempts24h %></h3>
    <span class="mini-note">Unique IPs / 7d: <%= metrics.uniqueAdminIps7d %></span>
  </article>
  <article class="card stat-card">
    <p>Blocked admin attempts (7d)</p>
    <h3><%= metrics.blockedAdminAttempts7d %></h3>
    <span class="mini-note">Guest, unverified, wrong role, wrong key, or invalid config</span>
  </article>
</section>

<section class="split-grid">
  <article class="card">
    <div class="section-head">
      <h3><%= t('admin.section.planBreakdown', 'Plan breakdown') %></h3>
    </div>
    <div class="list-stack">
      <div class="list-item">
        <div>
          <h4>Free</h4>
        </div>
        <span class="mini-label"><%= breakdown.plans.free %></span>
      </div>
      <div class="list-item">
        <div>
          <h4>Pro</h4>
        </div>
        <span class="mini-label"><%= breakdown.plans.pro %></span>
      </div>
      <div class="list-item">
        <div>
          <h4>Premium</h4>
        </div>
        <span class="mini-label"><%= breakdown.plans.premium %></span>
      </div>
    </div>
  </article>

  <article class="card">
    <div class="section-head">
      <h3><%= t('admin.section.episodeStatus', 'Episode status distribution') %></h3>
    </div>
    <div class="list-stack">
      <% ['Planned', 'Draft', 'Ready', 'Served'].forEach((status) => { %>
        <div class="list-item">
          <div>
            <h4><%= status %></h4>
          </div>
          <div class="inline-actions">
            <span class="badge badge-<%= status.toLowerCase() %>"><%= status %></span>
            <span class="mini-label"><%= breakdown.episodeStatus[status] || 0 %></span>
          </div>
        </div>
      <% }) %>
    </div>
  </article>
</section>

<section class="card">
  <div class="section-head">
    <h3>Recent admin access attempts</h3>
    <span class="mini-label">Visitor tracking</span>
  </div>
  <% if (!recentAdminAccess.length) { %>
    <p class="empty-state">No admin access activity recorded yet.</p>
  <% } else { %>
    <div class="list-stack">
      <% recentAdminAccess.forEach((entry) => { %>
        <% const outcomeLabel = String(entry.outcome || '').replace(/_/g, ' '); %>
        <div class="list-item">
          <div>
            <h4><%= entry.userEmail || 'Anonymous visitor' %></h4>
            <p><%= entry.requestPath %> · <%= entry.ipAddress || 'IP unavailable' %></p>
            <p class="mini-note">
              <%= new Date(entry.createdAt).toLocaleString() %>
              · role: <%= entry.userRole || 'guest' %>
              · key: <%= entry.hasAdminKey ? entry.keySource : 'none' %>
            </p>
          </div>
          <span class="mini-label"><%= outcomeLabel %></span>
        </div>
      <% }) %>
    </div>
  <% } %>
</section>

<section class="card">
  <div class="section-head">
    <h3>Newest signup emails</h3>
    <span class="mini-label">Admin only</span>
  </div>
  <% if (!recentUsers.length) { %>
    <p class="empty-state"><%= t('admin.empty.recentUsers', 'No users yet.') %></p>
  <% } else { %>
    <div class="admin-email-export">
      <p class="mini-note">Latest signup emails. Copy this list if you need a quick export.</p>
      <pre><%= signupEmailList %></pre>
    </div>
    <div class="list-stack">
      <% recentUsers.forEach((user) => { %>
        <div class="list-item admin-signup-item">
          <div>
            <h4><%= user.email %></h4>
            <p><%= user.name || 'Unnamed user' %></p>
            <p class="mini-note"><%= new Date(user.createdAt).toLocaleString() %></p>
          </div>
          <div class="inline-actions admin-signup-meta">
            <span class="mini-label"><%= user.authProvider || 'local' %></span>
            <span class="mini-label"><%= user.emailVerified ? 'verified' : 'pending verify' %></span>
            <span class="mini-label"><%= user.plan %></span>
            <span class="mini-label"><%= user.planStatus %></span>
          </div>
        </div>
      <% }) %>
    </div>
  <% } %>
</section>

<section class="card">
  <div class="section-head">
    <h3>Users directory</h3>
    <span class="mini-label"><%= userDirectory.length %> users</span>
  </div>
  <% if (!userDirectory.length) { %>
    <p class="empty-state">No users to list yet.</p>
  <% } else { %>
    <p class="mini-note">Newest accounts first. Join date is shown in your local admin timezone.</p>
    <div class="admin-table-shell">
      <table class="admin-user-table">
        <thead>
          <tr>
            <th>Joined</th>
            <th>Name</th>
            <th>Email</th>
            <th>Auth</th>
            <th>Verified</th>
            <th>Plan</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          <% userDirectory.forEach((user) => { %>
            <tr>
              <td><span class="admin-table-date"><%= new Date(user.createdAt).toLocaleString() %></span></td>
              <td><strong><%= user.name || 'Unnamed user' %></strong></td>
              <td><span class="admin-table-email"><%= user.email %></span></td>
              <td><span class="mini-label"><%= user.authProvider || 'local' %></span></td>
              <td>
                <span class="mini-label"><%= user.emailVerified ? 'verified' : 'pending' %></span>
              </td>
              <td><span class="mini-label"><%= user.plan %></span></td>
              <td><span class="mini-label"><%= user.planStatus %></span></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</section>

<section class="split-grid">
  <article class="card">
    <div class="section-head">
      <h3><%= t('admin.section.recentEpisodes', 'Recent episode activity') %></h3>
    </div>
    <% if (!recentEpisodes.length) { %>
      <p class="empty-state"><%= t('admin.empty.recentEpisodes', 'No episode activity yet.') %></p>
    <% } else { %>
      <div class="list-stack">
        <% recentEpisodes.forEach((episode) => { %>
          <div class="list-item">
            <div>
              <h4><%= episode.title || `${t('common.episode', 'Episode')} ${episode.episodeNumberWithinTheme || '?'}` %></h4>
              <p><%= episode.seriesId?.name || 'N/A' %> · <%= episode.userId?.name || episode.userId?.email || t('generic.user', 'User') %></p>
              <p class="mini-note"><%= new Date(episode.updatedAt).toLocaleString() %></p>
            </div>
            <div class="inline-actions">
              <span class="mini-label"><%= episode.isSingle ? 'Single' : 'Series' %></span>
              <span class="badge badge-<%= String(episode.status || '').toLowerCase() %>"><%= episode.status %></span>
            </div>
          </div>
        <% }) %>
      </div>
    <% } %>
  </article>

  <article class="card">
    <div class="section-head">
      <h3><%= t('admin.section.recentIdeas', 'Recent pantry activity') %></h3>
    </div>
    <% if (!recentIdeas.length) { %>
      <p class="empty-state"><%= t('admin.empty.recentIdeas', 'No pantry activity yet.') %></p>
    <% } else { %>
      <div class="list-stack">
        <% recentIdeas.forEach((idea) => { %>
          <div class="list-item">
            <div>
              <h4><%= idea.hook %></h4>
              <p><%= idea.userId?.name || idea.userId?.email || t('generic.user', 'User') %></p>
              <p class="mini-note"><%= new Date(idea.updatedAt).toLocaleString() %></p>
            </div>
            <span class="mini-label"><%= idea.tag || 'general' %></span>
          </div>
        <% }) %>
      </div>
    <% } %>
  </article>
</section>
