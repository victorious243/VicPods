<section id="onboarding-studio-start" class="card studio-hero-card">
  <div class="studio-hero-grid">
    <div class="studio-hero-copy">
      <span class="mini-label studio-hero-kicker">Command center</span>
      <h3>Start your next episode with structure.</h3>
      <p>Move from rough topic to launch-ready prep in one focused workflow.</p>

      <div class="inline-actions studio-hero-actions">
        <a href="/kitchen" class="btn btn-primary">Open Workspace</a>
        <a id="onboarding-start-single" href="/create/single" class="btn btn-secondary">New Single Episode</a>
        <a id="onboarding-start-series" href="/create/series" class="btn btn-ghost">Start Series</a>
      </div>
    </div>

    <aside class="studio-hero-side">
      <article class="studio-hero-stat">
        <span class="mini-label">Current access</span>
        <strong><%= effectivePlan === 'free' ? 'Free plan' : `${effectivePlan.charAt(0).toUpperCase()}${effectivePlan.slice(1)} plan` %></strong>
      </article>
      <article class="studio-hero-stat">
        <span class="mini-label">AI remaining today</span>
        <strong><%= stats.aiRemaining %></strong>
      </article>
      <article class="studio-hero-stat">
        <span class="mini-label">Next milestone</span>
        <strong><%= activationChecklist.nextStep?.label || 'Open Workspace' %></strong>
      </article>
      <a id="onboarding-open-settings" href="/settings?section=appearance" class="btn btn-tertiary studio-hero-settings">Open Settings</a>
    </aside>
  </div>
</section>

<section class="studio-growth-grid">
  <article class="card activation-checklist-card">
    <div class="section-head">
      <div>
        <h3>First-Week Activation</h3>
        <p class="mini-note">A short path from zero to shareable output.</p>
      </div>
      <span class="mini-label"><%= activationChecklist.completedCount %>/<%= activationChecklist.totalCount %> complete</span>
    </div>

    <div class="activation-progress-bar" aria-hidden="true">
      <span style="width:<%= activationChecklist.progressPercent %>%"></span>
    </div>

    <div class="activation-checklist-steps">
      <% activationChecklist.steps.forEach((step, index) => { %>
        <article class="activation-checklist-step <%= step.complete ? 'is-complete' : '' %>">
          <div class="activation-checklist-index"><%= String(index + 1).padStart(2, '0') %></div>
          <div class="activation-checklist-copy">
            <strong><%= step.label %></strong>
            <p><%= step.description %></p>
          </div>
          <a href="<%= step.href %>" class="btn <%= step.complete ? 'btn-ghost' : 'btn-secondary' %>"><%= step.complete ? 'Open' : step.ctaLabel %></a>
        </article>
      <% }) %>
    </div>
  </article>

  <article class="card referral-growth-card">
    <div class="section-head">
      <div>
        <h3>Referral Loop</h3>
        <p class="mini-note">Invite creators. Unlock extra usage.</p>
      </div>
      <span class="mini-label">+<%= referralProgram.rewardPerReferral %> AI credits/day per verified invite</span>
    </div>

    <p>When another creator joins through your link and verifies their account, VicPods adds more daily AI capacity automatically.</p>

    <label class="share-link-field">
      <span class="landing-preview-label">Your invite link</span>
      <input type="text" value="<%= referralProgram.inviteUrl %>" readonly data-copy-source="studio-referral-link" />
    </label>

    <div class="inline-actions">
      <button class="btn btn-primary" type="button" data-copy-trigger="studio-referral-link" data-copy-label="Copy Invite Link">Copy Invite Link</button>
      <a href="/examples" class="btn btn-ghost">Examples</a>
    </div>

    <div class="referral-growth-stats">
      <article>
        <span class="mini-label">Verified invites</span>
        <strong><%= referralProgram.referralCount %></strong>
      </article>
      <article>
        <span class="mini-label">Bonus AI credits/day</span>
        <strong>+<%= referralProgram.referralBonusCredits %></strong>
      </article>
      <article>
        <span class="mini-label">Current daily ceiling</span>
        <strong><%= stats.aiLimit === null ? 'Unlimited' : stats.aiLimit %></strong>
      </article>
    </div>
  </article>
</section>

<section class="card-grid stats-grid" id="onboarding-stats">
  <a id="onboarding-stats-series" class="card stat-card stat-card-link <%= selectedInspect === 'series' ? 'active-stat-card' : '' %>" href="/studio?inspect=series">
    <p>Series</p>
    <h3><%= stats.seriesCount %></h3>
    <span class="mini-note">Open list</span>
  </a>
  <a class="card stat-card stat-card-link <%= selectedInspect === 'episodes' ? 'active-stat-card' : '' %>" href="/studio?inspect=episodes">
    <p>Episodes</p>
    <h3><%= stats.episodeCount %></h3>
    <span class="mini-note">Open list</span>
  </a>
  <a class="card stat-card stat-card-link <%= selectedInspect === 'single' ? 'active-stat-card' : '' %>" href="/studio?inspect=single">
    <p>Single</p>
    <h3><%= stats.singleEpisodeCount %></h3>
    <span class="mini-note">Open list</span>
  </a>
  <a class="card stat-card stat-card-link <%= selectedInspect === 'ready' ? 'active-stat-card' : '' %>" href="/studio?inspect=ready">
    <p>Ready</p>
    <h3><%= stats.readyCount %></h3>
    <span class="mini-note">Open list</span>
  </a>
  <a class="card stat-card stat-card-link <%= selectedInspect === 'served' ? 'active-stat-card' : '' %>" href="/studio?inspect=served">
    <p>Served</p>
    <h3><%= stats.servedCount %></h3>
    <span class="mini-note">Open list</span>
  </a>
  <a class="card stat-card stat-card-link <%= selectedInspect === 'ideas' ? 'active-stat-card' : '' %>" href="/studio?inspect=ideas">
    <p>Ideas</p>
    <h3><%= stats.ideaCount %></h3>
    <span class="mini-note">Open list</span>
  </a>
  <a class="card stat-card stat-card-link wide <%= selectedInspect === 'ai' ? 'active-stat-card' : '' %>" href="/studio?inspect=ai">
    <p>Chef AI Credits Today</p>
    <h3><%= stats.aiRemaining %></h3>
    <span class="mini-note"><%= stats.aiLimitNote %></span>
  </a>
</section>

<% if (inspectPanel) { %>
  <section class="card">
    <div class="section-head">
      <h3><%= inspectPanel.title %></h3>
      <a href="/studio" class="btn btn-ghost">Clear</a>
    </div>

    <% if (inspectPanel.key === 'ai') { %>
      <p><strong>Remaining today:</strong> <%= stats.aiRemaining %></p>
      <p class="mini-note">Need more AI generations? Upgrade your plan for higher limits.</p>
      <a href="/settings?section=billing" class="btn btn-secondary">Open Billing</a>
    <% } else if (!inspectPanel.items.length) { %>
      <p class="empty-state">No items found in this category yet.</p>
    <% } else if (inspectPanel.key === 'series') { %>
      <div class="list-stack">
        <% inspectPanel.items.forEach((series) => { %>
          <a class="list-item" href="/kitchen/<%= series._id %>">
            <div>
              <h4><%= series.name %></h4>
              <p><%= series.creationMode === 'single_collection' ? 'Single collection' : 'Series workspace' %></p>
              <% if (series.description) { %>
                <p><%= series.description %></p>
              <% } %>
            </div>
            <span class="chevron">›</span>
          </a>
        <% }) %>
      </div>
    <% } else if (inspectPanel.key === 'ideas') { %>
      <div class="list-stack">
        <% inspectPanel.items.forEach((idea) => { %>
          <a class="list-item" href="/pantry">
            <div>
              <h4><%= idea.hook %></h4>
              <p>
                <%= idea.tag || 'Uncategorized' %>
                <% if (idea.notes) { %>
                  · <%= idea.notes %>
                <% } %>
              </p>
            </div>
            <span class="chevron">›</span>
          </a>
        <% }) %>
      </div>
    <% } else { %>
      <div class="list-stack">
        <% inspectPanel.items.forEach((episode) => { %>
          <% const hasTheme = Boolean(episode.themeId?._id); %>
          <a
            class="list-item"
            href="<%= hasTheme ? `/kitchen/${episode.seriesId?._id}/themes/${episode.themeId?._id}/episodes/${episode._id}` : `/kitchen/${episode.seriesId?._id}` %>"
          >
            <div>
              <h4><%= episode.title || `Episode ${episode.episodeNumberWithinTheme || '?'}` %></h4>
              <p>
                <%= episode.isSingle ? 'Single Episode' : (episode.seriesId?.name || 'Series') %>
                · <%= episode.themeId?.name || 'Theme pending' %>
                · Episode <%= episode.episodeNumberWithinTheme || '?' %>
              </p>
            </div>
            <div class="inline-actions">
              <span class="mini-label"><%= episode.isSingle ? 'Single' : 'Series' %></span>
              <span class="badge badge-<%= episode.status.toLowerCase() %>"><%= episode.status %></span>
            </div>
          </a>
        <% }) %>
      </div>
    <% } %>
  </section>
<% } %>

<section class="card" id="onboarding-studio-recents">
  <div class="section-head">
    <h3>Recent Episodes</h3>
    <a id="onboarding-open-kitchen" href="/kitchen" class="btn btn-ghost">Open Workspace</a>
  </div>

  <div class="chip-wrap studio-filter-bar">
    <a class="chip studio-filter-chip <%= selectedFilter === 'all' ? 'active-chip' : '' %>" href="/studio">All</a>
    <a class="chip studio-filter-chip <%= selectedFilter === 'single' ? 'active-chip' : '' %>" href="/studio?filter=single">Single</a>
    <a class="chip studio-filter-chip <%= selectedFilter === 'series' ? 'active-chip' : '' %>" href="/studio?filter=series">Series</a>
    <a class="chip studio-filter-chip <%= selectedFilter === 'ready' ? 'active-chip' : '' %>" href="/studio?filter=ready">Ready</a>
    <a class="chip studio-filter-chip <%= selectedFilter === 'served' ? 'active-chip' : '' %>" href="/studio?filter=served">Served</a>
  </div>

  <% if (!latestEpisodes.length) { %>
    <p class="empty-state">No episodes yet. Open Workspace to start your first episode.</p>
  <% } else { %>
    <div class="list-stack studio-recent-list">
      <% latestEpisodes.forEach((episode) => { %>
        <% const hasTheme = Boolean(episode.themeId?._id); %>
        <a
          class="list-item studio-recent-item"
          href="<%= hasTheme ? `/kitchen/${episode.seriesId?._id}/themes/${episode.themeId?._id}/episodes/${episode._id}` : `/kitchen/${episode.seriesId?._id}` %>"
        >
          <div class="studio-recent-main">
            <h4><%= episode.title || `Episode ${episode.episodeNumberWithinTheme || '?'}` %></h4>
            <p>
              <%= episode.isSingle ? 'Single Episode' : (episode.seriesId?.name || 'Series') %>
              · <%= episode.themeId?.name || 'Theme pending' %>
              · Episode <%= episode.episodeNumberWithinTheme || '?' %>
            </p>
          </div>
          <div class="inline-actions">
            <span class="mini-label"><%= episode.isSingle ? 'Single' : 'Series' %></span>
            <span class="badge badge-<%= episode.status.toLowerCase() %>"><%= episode.status %></span>
          </div>
        </a>
      <% }) %>
    </div>
  <% } %>
</section>
