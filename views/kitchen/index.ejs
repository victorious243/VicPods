<section class="card">
  <div class="section-head">
    <h3>Workspace</h3>
    <div class="inline-actions">
      <a href="/create/single" class="btn btn-primary">New Episode</a>
      <a href="/create/series" class="btn btn-secondary">New Series</a>
    </div>
  </div>
  <p>Workspace is where you start new episodes, launch new series, and manage every draft already in progress.</p>
</section>

<% if (singleCollectionSeries) { %>
  <section class="card single-collection-card">
    <div class="section-head">
      <h3>Single Episodes</h3>
      <span class="mini-label">System Collection</span>
    </div>
    <p>All standalone episodes live here, so quick one-off creations and existing drafts stay in one organized place.</p>
    <div class="inline-actions">
      <a href="/create/single" class="btn btn-primary">New Episode</a>
      <a href="/kitchen/<%= singleCollectionSeries._id %>" class="btn btn-ghost">Open Collection</a>
    </div>
  </section>
<% } %>

<section class="card">
  <div class="section-head">
    <h3>Your Series</h3>
    <span class="mini-label"><%= regularSeries.length %> total</span>
  </div>

  <% if (!regularSeries.length) { %>
    <p class="empty-state">No series yet. Start a new series from Workspace.</p>
  <% } else { %>
    <div class="list-stack">
      <% regularSeries.forEach((series) => { %>
        <a class="list-item" href="/kitchen/<%= series._id %>">
          <div>
            <h4><%= series.name %></h4>
            <p>
              <%= series.tonePreset || 'Conversational & Casual' %> ·
              <%= Math.min(series.toneIntensity || 3, maxToneIntensity || 5) %>/5 ·
              <%= series.audienceType || 'Mixed' %> ·
              intent: <%= series.intent || 'educate' %>
            </p>
            <% if (series.goal) { %>
              <p><strong>Goal:</strong> <%= series.goal %></p>
            <% } %>
          </div>
          <span class="chevron">›</span>
        </a>
      <% }) %>
    </div>
  <% } %>
</section>
