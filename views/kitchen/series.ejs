<section class="card">
  <div class="section-head">
    <h3>Series Brief</h3>
    <a href="/kitchen" class="btn btn-ghost">Back to Workspace</a>
  </div>
  <p>
    <strong>Mode:</strong> <%= isSystemSingleCollection ? 'Single Collection' : 'Series' %>
    · <strong>Tone:</strong> <%= series.tonePreset || 'Conversational & Casual' %> (<%= Math.min(series.toneIntensity || 3, maxToneIntensity || 5) %>/5)
    · <strong>Audience Type:</strong> <%= series.audienceType || 'Mixed' %>
    · <strong>Intent:</strong> <%= series.intent || 'educate' %>
    · <strong>Planned Episodes:</strong> <%= series.plannedEpisodeCount || 0 %>
  </p>
  <% if (series.goal) { %>
    <p><strong>Primary Goal:</strong> <%= series.goal %></p>
  <% } %>
  <% if (resolvedSeriesBible.seasonGoal) { %>
    <p><strong>Season Goal:</strong> <%= resolvedSeriesBible.seasonGoal %></p>
  <% } %>
  <% if (resolvedSeriesBible.audiencePromise) { %>
    <p><strong>Audience Promise:</strong> <%= resolvedSeriesBible.audiencePromise %></p>
  <% } %>
  <% if (resolvedSeriesBible.recurringThemes.length) { %>
    <p><strong>Recurring Themes:</strong> <%= resolvedSeriesBible.recurringThemes.join(' · ') %></p>
  <% } %>
  <% if (resolvedSeriesBlueprint.audienceProblem) { %>
    <p><strong>Audience Problem:</strong> <%= resolvedSeriesBlueprint.audienceProblem %></p>
  <% } %>
  <% if (resolvedSeriesBlueprint.listenerTransformation) { %>
    <p><strong>Listener Transformation:</strong> <%= resolvedSeriesBlueprint.listenerTransformation %></p>
  <% } %>
  <% if (resolvedSeriesBlueprint.contentPillars.length) { %>
    <p><strong>Content Pillars:</strong> <%= resolvedSeriesBlueprint.contentPillars.join(' · ') %></p>
  <% } %>
  <p>
    <strong>Episode Architect:</strong>
    <%= formatTemplateOptions.find((option) => option.value === resolvedSeriesStructure.defaultFormatTemplate)?.label || 'Signature Framework' %>
    · <%= hookStyleOptions.find((option) => option.value === resolvedSeriesStructure.defaultHookStyle)?.label || 'Problem First' %>
    · <%= targetLengthOptions.find((option) => option.value === resolvedSeriesStructure.defaultTargetLength)?.presetLabel || 'Flexible' %>
    · <%= deliveryStyleOptions.find((option) => option.value === (series.defaultDeliveryStyle || 'friendly'))?.label || 'Friendly' %>
  </p>
  <% if (resolvedSeriesBlueprint.brandVoiceRules.length) { %>
    <p><strong>Brand Voice Rules:</strong> <%= resolvedSeriesBlueprint.brandVoiceRules.join(' · ') %></p>
  <% } %>
  <% if (resolvedSeriesBlueprint.bannedWords.length) { %>
    <p><strong>Banned Words:</strong> <%= resolvedSeriesBlueprint.bannedWords.join(', ') %></p>
  <% } %>
  <p><%= series.description || (isSystemSingleCollection ? 'System-managed standalone episodes collection.' : 'No series description yet.') %></p>
  <% if (series.seriesSummary) { %>
    <p><strong>Series Continuity Summary:</strong> <%= series.seriesSummary %></p>
  <% } %>
  <% if (series.voicePersona) { %>
    <p><strong>Voice Persona:</strong> <%= series.voicePersona %></p>
  <% } %>
</section>

<% if (isSystemSingleCollection) { %>
  <section class="card">
    <div class="section-head">
      <h3>Single Episodes</h3>
      <a href="/create/single" class="btn btn-primary">New Single Episode</a>
    </div>

    <% if (!flatEpisodes.length) { %>
      <p class="empty-state">No standalone episodes yet. Start one from Workspace.</p>
    <% } else { %>
      <div class="episode-divider-stack">
        <% flatEpisodes.forEach((episode) => { %>
          <article class="episode-block">
            <header>
              <h4>
                Episode <%= episode.episodeNumberWithinTheme %>
                <% if (episode.globalEpisodeNumber) { %>
                  · Global <%= episode.globalEpisodeNumber %>
                <% } %>
                · <%= episode.title || 'Untitled' %>
              </h4>
              <span class="badge badge-<%= episode.status.toLowerCase() %>"><%= episode.status %></span>
            </header>
            <p><%= episode.hook || 'No hook yet.' %></p>
            <div class="inline-actions">
              <span class="mini-label"><%= episode.episodeType || 'solo' %></span>
              <% if (episode.targetLength) { %>
                <span class="mini-label"><%= targetLengthOptions.find((option) => option.value === episode.targetLength)?.presetLabel || episode.targetLength %></span>
              <% } %>
              <span class="mini-label"><%= formatTemplateOptions.find((option) => option.value === episode.formatTemplate)?.label || 'Signature Framework' %></span>
            </div>
            <a class="btn btn-ghost" href="/kitchen/<%= series._id %>/themes/<%= episode.themeId %>/episodes/<%= episode._id %>">
              Edit Episode
            </a>
          </article>
        <% }) %>
      </div>
    <% } %>
  </section>
<% } else { %>
  <section class="split-grid">
    <article class="card">
      <div class="section-head">
        <h3>Series Settings</h3>
        <span class="mini-label">Tone Engine v1</span>
      </div>

      <form action="/kitchen/<%= series._id %>/settings" method="POST" class="form-grid">
        <label>
          Series Name
          <input type="text" name="name" maxlength="120" value="<%= series.name %>" required />
        </label>

        <label>
          Description
          <textarea name="description" rows="3" maxlength="1000"><%= series.description %></textarea>
        </label>

        <label>
          Target Audience Notes
          <input type="text" name="audience" maxlength="240" value="<%= series.audience %>" />
        </label>

        <label>
          Primary Goal
          <input type="text" name="goal" maxlength="320" value="<%= series.goal %>" />
        </label>

        <div class="tone-section">
          <div class="section-head">
            <h4>Series Tone</h4>
            <span class="mini-label"><%= effectivePlan === 'free' ? 'Free max 3/5 intensity' : 'Full tone controls' %></span>
          </div>

          <div class="tone-grid">
            <% tonePresets.forEach((preset) => { %>
              <label class="tone-card">
                <input type="radio" name="tonePreset" value="<%= preset.name %>" <%= (series.tonePreset || 'Conversational & Casual') === preset.name ? 'checked' : '' %> />
                <span class="tone-card-title"><%= preset.name %></span>
                <span class="tone-card-desc"><%= preset.description %></span>
                <span class="tone-card-example">"<%= preset.exampleHook %>"</span>
              </label>
            <% }) %>
          </div>

          <label>
            Tone Intensity (<span data-range-value="tone-intensity-series"><%= Math.min(series.toneIntensity || 3, maxToneIntensity || 3) %></span>/5)
            <input
              id="tone-intensity-series"
              type="range"
              name="toneIntensity"
              min="1"
              max="<%= maxToneIntensity || 3 %>"
              value="<%= Math.min(series.toneIntensity || 3, maxToneIntensity || 3) %>"
              data-range-source="tone-intensity-series"
            />
          </label>
        </div>

        <div class="tone-section">
          <div class="section-head">
            <h4>Series Bible</h4>
            <span class="mini-label">Season Planning</span>
          </div>

          <div class="two-col">
            <label>
              Season Goal
              <input type="text" name="seasonGoal" maxlength="320" value="<%= resolvedSeriesBible.seasonGoal %>" />
            </label>
            <label>
              Audience Promise
              <input type="text" name="audiencePromise" maxlength="240" value="<%= resolvedSeriesBible.audiencePromise %>" />
            </label>
          </div>

          <label>
            Recurring Themes
            <textarea name="recurringThemes" rows="3" maxlength="480"><%= resolvedSeriesBible.recurringThemes.join('\n') %></textarea>
          </label>
        </div>

        <div class="tone-section">
          <div class="section-head">
            <h4>Show Blueprint</h4>
            <span class="mini-label">Structuring App</span>
          </div>

          <div class="two-col">
            <label>
              Audience Problem
              <input type="text" name="audienceProblem" maxlength="240" value="<%= resolvedSeriesBlueprint.audienceProblem %>" />
            </label>
            <label>
              Listener Transformation
              <input type="text" name="listenerTransformation" maxlength="240" value="<%= resolvedSeriesBlueprint.listenerTransformation %>" />
            </label>
          </div>

          <label>
            Content Pillars
            <textarea name="contentPillars" rows="3" maxlength="480"><%= resolvedSeriesBlueprint.contentPillars.join('\n') %></textarea>
          </label>

          <div class="two-col">
            <label>
              CTA Style
              <select name="ctaStyle">
                <% ctaStyleOptions.forEach((option) => { %>
                  <option value="<%= option.value %>" <%= resolvedSeriesBlueprint.ctaStyle === option.value ? 'selected' : '' %>><%= option.label %></option>
                <% }) %>
              </select>
            </label>
            <label>
              Brand Voice Rules
              <textarea name="brandVoiceRules" rows="3" maxlength="480"><%= resolvedSeriesBlueprint.brandVoiceRules.join('\n') %></textarea>
            </label>
          </div>

          <label>
            Banned Words or Phrases
            <textarea name="bannedWords" rows="2" maxlength="240"><%= resolvedSeriesBlueprint.bannedWords.join('\n') %></textarea>
          </label>
        </div>

        <div class="tone-section">
          <div class="section-head">
            <h4>Episode Architect Defaults</h4>
            <span class="mini-label">Inherited by new episodes</span>
          </div>

          <div class="two-col">
            <label>
              Default Format Template
              <select name="defaultFormatTemplate">
                <% formatTemplateOptions.forEach((option) => { %>
                  <option value="<%= option.value %>" <%= resolvedSeriesStructure.defaultFormatTemplate === option.value ? 'selected' : '' %>><%= option.label %></option>
                <% }) %>
              </select>
            </label>
            <label>
              Default Hook Style
              <select name="defaultHookStyle">
                <% hookStyleOptions.forEach((option) => { %>
                  <option value="<%= option.value %>" <%= resolvedSeriesStructure.defaultHookStyle === option.value ? 'selected' : '' %>><%= option.label %></option>
                <% }) %>
              </select>
            </label>
          </div>

          <div class="two-col">
            <label>
              Default Episode Type
              <select name="defaultEpisodeType">
                <% episodeTypeOptions.forEach((option) => { %>
                  <option value="<%= option.value %>" <%= resolvedSeriesStructure.defaultEpisodeType === option.value ? 'selected' : '' %>><%= option.label %></option>
                <% }) %>
              </select>
            </label>

            <label>
              Duration Preset
              <select name="defaultTargetLength">
                <% targetLengthOptions.forEach((option) => { %>
                  <option value="<%= option.value %>" <%= resolvedSeriesStructure.defaultTargetLength === option.value ? 'selected' : '' %>><%= option.label %></option>
                <% }) %>
              </select>
            </label>
          </div>

          <label>
            Default Delivery Style
            <select name="defaultDeliveryStyle">
              <% deliveryStyleOptions.forEach((option) => { %>
                <option value="<%= option.value %>" <%= (series.defaultDeliveryStyle || 'friendly') === option.value ? 'selected' : '' %>><%= option.label %></option>
              <% }) %>
            </select>
          </label>

          <label class="check-item">
            <input type="hidden" name="defaultIncludeFunSegment" value="off" />
            <input type="checkbox" name="defaultIncludeFunSegment" <%= resolvedSeriesStructure.defaultIncludeFunSegment !== false ? 'checked' : '' %> />
            <span>Include fun segment by default</span>
          </label>
        </div>

        <div class="two-col">
          <label>
            Audience Type
            <select name="audienceType">
              <% audienceTypes.forEach((audienceType) => { %>
                <option value="<%= audienceType %>" <%= (series.audienceType || 'Mixed') === audienceType ? 'selected' : '' %>><%= audienceType %></option>
              <% }) %>
            </select>
          </label>

          <label>
            Intent
            <select name="intent">
              <% intentOptions.forEach((intent) => { %>
                <option value="<%= intent %>" <%= (series.intent || 'educate') === intent ? 'selected' : '' %>><%= intent %></option>
              <% }) %>
            </select>
          </label>
        </div>

        <label>
          Custom Audience Type (optional)
          <input type="text" name="audienceTypeCustom" maxlength="120" placeholder="Use only when Audience Type is Custom" />
        </label>

        <% if (isPremiumPlan) { %>
          <label>
            Voice Persona (Premium)
            <textarea name="voicePersona" rows="3" maxlength="400" data-char-count="persona-series" placeholder="Describe how you speak. Keep it short."><%= series.voicePersona %></textarea>
            <small class="mini-note"><span data-char-count-label="persona-series"><%= (series.voicePersona || '').length %></span>/400</small>
          </label>
        <% } else { %>
          <label>
            Voice Persona (Premium)
            <textarea rows="3" disabled placeholder="Upgrade to Premium to save a voice persona."><%= series.voicePersona %></textarea>
            <small class="mini-note">Premium only. <a href="/settings?section=billing">Upgrade</a></small>
          </label>
        <% } %>

        <label>
          Planned Episode Count
          <input type="number" name="plannedEpisodeCount" min="0" value="<%= series.plannedEpisodeCount || 0 %>" />
        </label>

        <button type="submit" class="btn btn-primary">Save Series Settings</button>
      </form>
    </article>

    <article class="card">
      <div class="section-head">
        <h3>Create Theme</h3>
        <span class="mini-label">Series → Themes</span>
      </div>
      <form method="POST" action="/kitchen/<%= series._id %>/themes" class="form-grid">
        <label>
          Theme Name
          <input type="text" name="name" maxlength="120" required placeholder="Monetization Experiments" />
        </label>
        <label>
          Theme Description
          <textarea name="description" rows="3" maxlength="1000" placeholder="What this theme explores across episodes"></textarea>
        </label>
        <button type="submit" class="btn btn-primary">Create Theme</button>
      </form>
    </article>
  </section>

  <section class="card">
    <div class="section-head">
      <h3>Series Planning</h3>
      <span class="mini-label">Phase 3</span>
    </div>

    <p><strong>Continuity Health:</strong> <%= seriesPlanningSnapshot.continuityHealthScore %>/100</p>

    <% if (seriesPlanningSnapshot.seasonArc.length) { %>
      <p><strong>Season Arc:</strong></p>
      <div class="list-stack">
        <% seriesPlanningSnapshot.seasonArc.forEach((entry) => { %>
          <article class="list-item">
            <div>
              <h4>Arc Step</h4>
              <p><%= entry %></p>
            </div>
          </article>
        <% }) %>
      </div>
    <% } %>

    <% if (seriesPlanningSnapshot.continuityWarnings.length) { %>
      <p><strong>Continuity Checker:</strong> <%= seriesPlanningSnapshot.continuityWarnings.join(' · ') %></p>
    <% } else { %>
      <p class="mini-note">Continuity Checker does not see any major repeats or contradictions right now.</p>
    <% } %>

    <% if (seriesPlanningSnapshot.topicGapSuggestions.length) { %>
      <p><strong>Topic Gap Finder:</strong> <%= seriesPlanningSnapshot.topicGapSuggestions.join(' · ') %></p>
    <% } else { %>
      <p class="mini-note">Topic Gap Finder does not see any obvious missing series topics yet.</p>
    <% } %>

    <% if (seriesPlanningSnapshot.callbackPlan.length) { %>
      <p><strong>Callback Planner:</strong> <%= seriesPlanningSnapshot.callbackPlan.join(' · ') %></p>
    <% } else { %>
      <p class="mini-note">Add more published or drafted episodes to unlock stronger callback planning.</p>
    <% } %>
  </section>

  <section class="card">
    <div class="section-head">
      <h3>Themes & Episodes</h3>
      <span class="mini-label">Nested workflow</span>
    </div>

    <% if (!themesWithEpisodes.length) { %>
      <p class="empty-state">No themes yet for this series.</p>
    <% } else { %>
      <div class="theme-stack">
        <% themesWithEpisodes.forEach((entry, index) => { %>
          <% const theme = entry.theme; %>
          <% const episodes = entry.episodes; %>
          <% const firstEpisode = episodes[0]; %>
          <details class="theme-card" id="theme-<%= theme._id %>" <%= index === 0 ? 'open' : '' %>>
            <summary class="theme-summary">
              <div>
                <h4><%= theme.name %></h4>
                <p><%= theme.description || 'No theme description yet.' %></p>
              </div>
              <div class="inline-actions">
                <span class="mini-label"><%= entry.progress.servedCount %>/<%= entry.progress.totalCount %> served</span>
                <% if (firstEpisode) { %>
                  <a class="btn btn-ghost" href="/kitchen/<%= series._id %>/themes/<%= theme._id %>/episodes/<%= firstEpisode._id %>">Open</a>
                <% } %>
              </div>
            </summary>

            <div class="theme-body">
              <% if (theme.themeSummary) { %>
                <p><strong>Theme Summary:</strong> <%= theme.themeSummary %></p>
              <% } %>

              <form method="POST" action="/kitchen/<%= series._id %>/themes/<%= theme._id %>/episodes" class="theme-add-episode">
                <label>
                  Episode Number (within <%= theme.name %>)
                  <input type="number" name="episodeNumberWithinTheme" min="1" placeholder="Auto" />
                </label>
                <label>
                  Working Title
                  <input type="text" name="title" maxlength="160" placeholder="Episode title" />
                </label>
                <button type="submit" class="btn btn-secondary">Add Episode</button>
              </form>

              <% if (!episodes.length) { %>
                <p class="empty-state">No episodes in this theme yet.</p>
              <% } else { %>
                <div class="episode-divider-stack">
                  <% episodes.forEach((episode) => { %>
                    <article class="episode-block">
                      <header>
                        <h4>
                          Theme Ep <%= episode.episodeNumberWithinTheme %>
                          <% if (episode.globalEpisodeNumber) { %>
                            · Global <%= episode.globalEpisodeNumber %>
                          <% } %>
                          · <%= episode.title || 'Untitled' %>
                        </h4>
                        <span class="badge badge-<%= episode.status.toLowerCase() %>"><%= episode.status %></span>
                      </header>
                      <p><%= episode.hook || 'No hook yet.' %></p>
                      <p class="mini-note">
                        <%= formatTemplateOptions.find((option) => option.value === episode.formatTemplate)?.label || 'Signature Framework' %>
                        · <%= hookStyleOptions.find((option) => option.value === episode.hookStyle)?.label || 'Problem First' %>
                        <% if (episode.targetLength) { %>
                          · <%= targetLengthOptions.find((option) => option.value === episode.targetLength)?.presetLabel || episode.targetLength %>
                        <% } %>
                      </p>
                      <a class="btn btn-ghost" href="/kitchen/<%= series._id %>/themes/<%= theme._id %>/episodes/<%= episode._id %>">
                        Edit Theme Episode <%= episode.episodeNumberWithinTheme %>
                      </a>
                    </article>
                  <% }) %>
                </div>
              <% } %>
            </div>
          </details>
        <% }) %>
      </div>
    <% } %>
  </section>
<% } %>
