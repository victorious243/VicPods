<% const isToneOverride = Boolean(episode.toneOverridePreset); %>
<% const toneLabel = effectiveTone?.toneSource === 'override' ? 'Override' : 'Inherited'; %>

<section class="card">
  <div class="section-head">
    <h3>Chef AI</h3>
    <div class="inline-actions">
      <form method="POST" action="/ai/episode/generate">
        <input type="hidden" name="seriesId" value="<%= series._id %>" />
        <input type="hidden" name="themeId" value="<%= theme._id %>" />
        <input type="hidden" name="episodeId" value="<%= episode._id %>" />
        <button class="btn btn-primary" type="submit">Generate Full Draft</button>
      </form>
      <form method="POST" action="/ai/spices/generate">
        <input type="hidden" name="seriesId" value="<%= series._id %>" />
        <input type="hidden" name="themeId" value="<%= theme._id %>" />
        <input type="hidden" name="episodeId" value="<%= episode._id %>" />
        <button class="btn btn-ghost" type="submit">Regenerate Spices</button>
      </form>
      <form method="POST" action="/ai/continuity/refresh">
        <input type="hidden" name="seriesId" value="<%= series._id %>" />
        <input type="hidden" name="themeId" value="<%= theme._id %>" />
        <input type="hidden" name="episodeId" value="<%= episode._id %>" />
        <button class="btn btn-muted" type="submit">Refresh Continuity</button>
      </form>
      <% if (toneFixAvailable) { %>
        <form method="POST" action="/ai/tone/fix">
          <input type="hidden" name="seriesId" value="<%= series._id %>" />
          <input type="hidden" name="themeId" value="<%= theme._id %>" />
          <input type="hidden" name="episodeId" value="<%= episode._id %>" />
          <button class="btn btn-secondary" type="submit">Auto-Fix Tone</button>
        </form>
      <% } else { %>
        <a class="btn btn-muted" href="/settings?section=billing">Auto-Fix Tone (Premium)</a>
      <% } %>
    </div>
  </div>
  <p class="mini-note">Spices = hook + host questions + fun segment. Tone Auto-Fix updates hook/questions/ending only.</p>
  <p><strong>Series Goal:</strong> <%= series.goal || 'Set a clear podcast growth objective.' %></p>
  <p><strong>Mode:</strong> <%= episode.isSingle ? 'Standalone single episode' : 'Series continuity episode' %></p>
  <p><strong>Tone:</strong> <%= toneLabel %> (<%= effectiveTone.tonePreset %>, <%= effectiveTone.toneIntensity %>/5)</p>
  <p><strong>Audience Type:</strong> <%= effectiveTone.audienceType || 'Mixed' %> · <strong>Intent:</strong> <%= effectiveTone.intent || 'educate' %></p>
  <p>
    <strong>Episode Architect:</strong>
    <%= resolvedStructure.formatTemplateMeta.label %> ·
    <%= resolvedStructure.hookStyleMeta.label %> ·
    <%= resolvedStructure.targetLengthMeta.presetLabel %>
  </p>
  <p><strong>Delivery Style:</strong> <%= deliveryStyleOptions.find((option) => option.value === effectiveDeliveryStyle)?.label || 'Friendly' %></p>
  <% if (resolvedBlueprint.audienceProblem) { %>
    <p><strong>Audience Problem:</strong> <%= resolvedBlueprint.audienceProblem %></p>
  <% } %>
  <% if (resolvedBlueprint.listenerTransformation) { %>
    <p><strong>Listener Transformation:</strong> <%= resolvedBlueprint.listenerTransformation %></p>
  <% } %>
  <% if (resolvedBlueprint.contentPillars.length) { %>
    <p><strong>Content Pillars:</strong> <%= resolvedBlueprint.contentPillars.join(' · ') %></p>
  <% } %>
  <% if (resolvedBlueprint.brandVoiceRules.length) { %>
    <p><strong>Brand Voice Rules:</strong> <%= resolvedBlueprint.brandVoiceRules.join(' · ') %></p>
  <% } %>
  <% if (resolvedBlueprint.bannedWords.length) { %>
    <p><strong>Banned Words:</strong> <%= resolvedBlueprint.bannedWords.join(', ') %></p>
  <% } %>
  <% if (theme.themeSummary) { %>
    <p><strong>Theme Summary:</strong> <%= theme.themeSummary %></p>
  <% } %>
<% if (previousEpisode?.endState) { %>
    <p><strong>Carry-forward from Theme Episode <%= previousEpisode.episodeNumberWithinTheme %>:</strong> <%= previousEpisode.endState %></p>
  <% } %>
  <% if (episodeContinuityContext?.seasonArcStep) { %>
    <p><strong>Season Arc Position:</strong> <%= episodeContinuityContext.seasonArcStep %></p>
  <% } %>
</section>

<section class="card">
  <div class="section-head">
    <h3>Release Readiness</h3>
    <span class="mini-label"><%= releaseReadiness?.stateLabel || 'Needs Work' %></span>
  </div>

  <p>
    <strong>Score:</strong> <%= releaseReadiness?.overallScore || 0 %>/100
    · completeness <%= releaseReadiness?.subscores?.completenessScore || 0 %>
    · quality <%= releaseReadiness?.subscores?.qualityScore || 0 %>
    · continuity <%= releaseReadiness?.subscores?.continuityScore || 0 %>
    · workflow <%= releaseReadiness?.subscores?.workflowScore || 0 %>
  </p>

  <% if (releaseReadiness?.briefEligible) { %>
    <p class="mini-note">This episode is eligible for Episode Brief export once the draft is locked.</p>
  <% } else { %>
    <p class="mini-note">Move the status to <strong>Ready</strong> or <strong>Served</strong> to unlock Episode Brief export.</p>
  <% } %>

  <% if (releaseReadiness?.blockers?.length) { %>
    <p><strong>Blockers:</strong> <%= releaseReadiness.blockers.join(' · ') %></p>
  <% } %>

  <% if (releaseReadiness?.strengths?.length) { %>
    <p><strong>Strengths:</strong> <%= releaseReadiness.strengths.join(' · ') %></p>
  <% } %>

  <% if (releaseReadiness?.nextActions?.length) { %>
    <p><strong>Next Actions:</strong> <%= releaseReadiness.nextActions.join(' · ') %></p>
  <% } %>
</section>

<section class="card">
  <div class="section-head">
    <h3>Episode Editor</h3>
    <a href="/kitchen/<%= series._id %>#theme-<%= theme._id %>" class="btn btn-ghost">Back to Theme</a>
  </div>

  <form method="POST" action="/kitchen/<%= series._id %>/themes/<%= theme._id %>/episodes/<%= episode._id %>" class="form-grid">
    <div class="two-col">
      <label>
        Episode Number (within theme)
        <input type="text" value="<%= episode.episodeNumberWithinTheme %>" disabled />
      </label>
      <label>
        Global Episode Number (series)
        <input type="text" value="<%= episode.globalEpisodeNumber || '-' %>" disabled />
      </label>
    </div>

    <div class="two-col">
      <label>
        Theme
        <input type="text" value="<%= theme.name %>" disabled />
      </label>
      <label>
        Status
        <select name="status">
          <% validStatuses.forEach((status) => { %>
            <option value="<%= status %>" <%= episode.status === status ? 'selected' : '' %>><%= status %></option>
          <% }) %>
        </select>
      </label>
    </div>

    <div class="two-col">
      <label>
        Episode Type
        <select name="episodeType">
          <option value="solo" <%= (episode.episodeType || 'solo') === 'solo' ? 'selected' : '' %>>Solo</option>
          <option value="interview" <%= (episode.episodeType || 'solo') === 'interview' ? 'selected' : '' %>>Interview</option>
        </select>
      </label>
      <label>
        Duration Preset
        <select name="targetLength">
          <% targetLengthOptions.forEach((option) => { %>
            <option value="<%= option.value %>" <%= resolvedStructure.targetLength === option.value ? 'selected' : '' %>><%= option.label %></option>
          <% }) %>
        </select>
      </label>
    </div>

    <div class="two-col">
      <label>
        Format Template
        <select name="formatTemplate">
          <% formatTemplateOptions.forEach((option) => { %>
            <option value="<%= option.value %>" <%= resolvedStructure.formatTemplate === option.value ? 'selected' : '' %>><%= option.label %></option>
          <% }) %>
        </select>
      </label>
      <label>
        Hook Style
        <select name="hookStyle">
          <% hookStyleOptions.forEach((option) => { %>
            <option value="<%= option.value %>" <%= resolvedStructure.hookStyle === option.value ? 'selected' : '' %>><%= option.label %></option>
          <% }) %>
        </select>
      </label>
    </div>

    <label>
      Delivery Style
      <select name="deliveryStyle">
        <% deliveryStyleOptions.forEach((option) => { %>
          <option value="<%= option.value %>" <%= effectiveDeliveryStyle === option.value ? 'selected' : '' %>><%= option.label %></option>
        <% }) %>
      </select>
    </label>

    <label class="check-item">
      <input type="hidden" name="includeFunSegment" value="off" />
      <input type="checkbox" name="includeFunSegment" <%= episode.includeFunSegment !== false ? 'checked' : '' %> />
      <span>Include fun segment</span>
    </label>

    <label>
      Title
      <input type="text" name="title" value="<%= episode.title %>" maxlength="160" />
      <small class="mini-note">Tone: <%= toneLabel %> (<%= effectiveTone.tonePreset %>, <%= effectiveTone.toneIntensity %>/5)</small>
    </label>

    <details class="tone-override-card" <%= isToneOverride ? 'open' : '' %>>
      <summary>Tone Override</summary>
      <div class="tone-override-body">
        <label class="check-item">
          <input type="checkbox" name="toneOverrideEnabled" data-tone-override-toggle <%= isToneOverride ? 'checked' : '' %> />
          <span>Override series tone for this episode</span>
        </label>

        <div class="tone-override-fields" data-tone-override-fields>
          <div class="tone-grid compact">
            <% tonePresets.forEach((preset) => { %>
              <label class="tone-card compact">
                <input
                  type="radio"
                  name="toneOverridePreset"
                  value="<%= preset.name %>"
                  <%= (episode.toneOverridePreset ? episode.toneOverridePreset : effectiveTone.tonePreset) === preset.name ? 'checked' : '' %>
                />
                <span class="tone-card-title"><%= preset.name %></span>
                <span class="tone-card-desc"><%= preset.description %></span>
              </label>
            <% }) %>
          </div>

          <label>
            Override Intensity (<span data-range-value="tone-intensity-episode"><%= Math.min(episode.toneOverrideIntensity || effectiveTone.toneIntensity || 3, maxToneIntensity || 3) %></span>/5)
            <input
              id="tone-intensity-episode"
              type="range"
              name="toneOverrideIntensity"
              min="1"
              max="<%= maxToneIntensity || 3 %>"
              value="<%= Math.min(episode.toneOverrideIntensity || effectiveTone.toneIntensity || 3, maxToneIntensity || 3) %>"
              data-range-source="tone-intensity-episode"
            />
          </label>
          <p class="mini-note">Free plan can use up to intensity 3.</p>
        </div>
      </div>
    </details>

    <% if (episode.isSingle) { %>
      <details class="tone-override-card" open>
        <summary>Single Episode Blueprint</summary>
        <div class="tone-override-body">
          <div class="two-col">
            <label>
              Audience Problem
              <input type="text" name="audienceProblem" maxlength="240" value="<%= resolvedBlueprint.audienceProblem %>" />
            </label>
            <label>
              Listener Transformation
              <input type="text" name="listenerTransformation" maxlength="240" value="<%= resolvedBlueprint.listenerTransformation %>" />
            </label>
          </div>

          <label>
            Content Pillars
            <textarea name="contentPillars" rows="3" maxlength="480"><%= resolvedBlueprint.contentPillars.join('\n') %></textarea>
          </label>

          <div class="two-col">
            <label>
              CTA Style
              <select name="ctaStyle">
                <% ctaStyleOptions.forEach((option) => { %>
                  <option value="<%= option.value %>" <%= resolvedBlueprint.ctaStyle === option.value ? 'selected' : '' %>><%= option.label %></option>
                <% }) %>
              </select>
            </label>
            <label>
              Brand Voice Rules
              <textarea name="brandVoiceRules" rows="3" maxlength="480"><%= resolvedBlueprint.brandVoiceRules.join('\n') %></textarea>
            </label>
          </div>

          <label>
            Banned Words or Phrases
            <textarea name="bannedWords" rows="2" maxlength="240"><%= resolvedBlueprint.bannedWords.join('\n') %></textarea>
          </label>
        </div>
      </details>
    <% } else { %>
      <p class="mini-note">This episode inherits show blueprint rules from the series workspace.</p>
    <% } %>

    <label>
      Hook (1-2 lines)
      <textarea name="hook" rows="2"><%= episode.hook %></textarea>
    </label>

    <label>
      Outline (one bullet per line, max 7)
      <textarea name="outline" rows="7"><%= (episode.outline || []).join('\n') %></textarea>
    </label>

    <label>
      Talking Points (one bullet per line, max 7)
      <textarea name="talkingPoints" rows="7"><%= (episode.talkingPoints || []).join('\n') %></textarea>
    </label>

    <label>
      Host Questions (one per line, max 8)
      <textarea name="hostQuestions" rows="8"><%= (episode.hostQuestions || []).join('\n') %></textarea>
    </label>

    <label>
      Fun Segment (game/dilemma)
      <textarea name="funSegment" rows="2"><%= episode.funSegment %></textarea>
    </label>

    <label>
      Ending (<%= episode.isSingle ? 'strong close, no teaser required' : 'takeaway + teaser' %>)
      <textarea name="ending" rows="2"><%= episode.ending %></textarea>
    </label>

    <label>
      Continuity End State (max 80 words)
      <textarea name="endState" rows="3"><%= episode.endState %></textarea>
    </label>

    <fieldset>
      <legend>Ingredients from Pantry</legend>
      <% if (!allIdeas.length) { %>
        <p class="empty-state">No pantry ideas yet.</p>
      <% } else { %>
        <div class="checkbox-grid">
          <% allIdeas.forEach((idea) => { %>
            <% const linked = (episode.ideaIds || []).some((episodeIdea) => String(episodeIdea._id || episodeIdea) === String(idea._id)); %>
            <label class="check-item">
              <input type="checkbox" name="ideaIds" value="<%= idea._id %>" <%= linked ? 'checked' : '' %> />
              <span><strong><%= idea.tag %></strong> · <%= idea.hook %></span>
            </label>
          <% }) %>
        </div>
      <% } %>
    </fieldset>

    <div class="inline-actions">
      <button type="submit" class="btn btn-primary">Save Episode</button>
    </div>
  </form>

  <form method="POST" action="/kitchen/<%= series._id %>/themes/<%= theme._id %>/episodes/<%= episode._id %>/delete" class="danger-form">
    <button type="submit" class="btn btn-danger">Delete Episode</button>
  </form>
</section>

<section class="card share-link-card">
  <div class="section-head">
    <h3>Share Episode</h3>
    <span class="mini-label">Read-only link</span>
  </div>

  <p class="mini-note">Share a clean public page with the episode title, hook, outline, and Launch Pack preview. No editing, no login required.</p>

  <div class="share-link-toolbar">
    <label class="share-link-field">
      <span class="landing-preview-label">Public share URL</span>
      <input type="text" value="<%= sharedEpisodeUrl %>" readonly data-copy-source="episode-share-url" />
    </label>

    <div class="inline-actions">
      <button class="btn btn-primary" type="button" data-copy-trigger="episode-share-url" data-copy-label="Copy Share Link" data-copy-complete-endpoint="/api/episodes/<%= episode._id %>/share/copied">Copy Share Link</button>
      <a class="btn btn-ghost" href="<%= sharedEpisodeUrl %>" target="_blank" rel="noopener noreferrer">Open Shared Page</a>
    </div>
  </div>

  <div class="share-growth-grid">
    <% if (effectivePlan === 'free') { %>
      <article class="card share-growth-card">
        <span class="mini-label">Watermarked Free Export</span>
        <h3>Download a light episode brief</h3>
        <p>Share a clean TXT preview with a subtle VicPods watermark while you keep building the full episode.</p>
        <div class="inline-actions">
          <a class="btn btn-secondary" href="/kitchen/<%= series._id %>/themes/<%= theme._id %>/episodes/<%= episode._id %>/preview/download">Download Preview TXT</a>
          <a class="btn btn-ghost" href="/settings?section=billing">Unlock full exports</a>
        </div>
      </article>
    <% } %>

    <article class="card share-growth-card">
      <span class="mini-label">Referral Loop</span>
      <h3>Invite another creator and earn more usage</h3>
      <p>Use your invite link after you share an episode. Each verified creator adds +<%= referralProgram.rewardPerReferral %> extra AI credits/day to your account.</p>
      <label class="share-link-field">
        <span class="landing-preview-label">Invite link</span>
        <input type="text" value="<%= referralProgram.inviteUrl %>" readonly data-copy-source="episode-referral-link" />
      </label>
      <div class="inline-actions">
        <button class="btn btn-primary" type="button" data-copy-trigger="episode-referral-link" data-copy-label="Copy Invite Link">Copy Invite Link</button>
        <span class="mini-label">+<%= referralProgram.referralBonusCredits %> credits/day active</span>
      </div>
    </article>
  </div>
</section>

<section class="card">
  <div class="section-head">
    <h3>Your Launch Pack</h3>
    <span class="mini-label">Publish-ready assets</span>
  </div>

  <div class="inline-actions">
    <form method="POST" action="/ai/launch-pack/generate">
      <input type="hidden" name="seriesId" value="<%= series._id %>" />
      <input type="hidden" name="themeId" value="<%= theme._id %>" />
      <input type="hidden" name="episodeId" value="<%= episode._id %>" />
      <button class="btn btn-primary" type="submit"><%= launchPackView?.updatedAt ? 'Refresh Launch Pack' : 'Generate Launch Pack' %></button>
    </form>
    <% if (launchPackFullAccess && launchPackView?.updatedAt) { %>
      <button class="btn btn-ghost" type="button" data-copy-trigger="launch-pack" data-copy-label="Copy Launch Pack">Copy Launch Pack</button>
    <% } %>
    <% if (!launchPackFullAccess) { %>
      <a class="btn btn-secondary" href="/settings?section=billing">Unlock full launch pack</a>
    <% } %>
    <% if (effectivePlan === 'free') { %>
      <a class="btn btn-ghost" href="/kitchen/<%= series._id %>/themes/<%= theme._id %>/episodes/<%= episode._id %>/preview/download">Download light preview</a>
    <% } %>
  </div>

  <% if (launchPackView?.updatedAt) { %>
    <p>
      Launch Pack ready.
      Last updated: <%= new Date(launchPackView.updatedAt).toLocaleString() %>
      <% if (launchPackView?.stale) { %>
        · refresh recommended after recent draft edits
      <% } %>
    </p>
  <% } else { %>
    <p class="mini-note">Generate title variations, description copy, show notes, social captions, and a publish CTA in one pass.</p>
  <% } %>

  <div class="launch-pack-grid">
    <article class="launch-pack-panel">
      <div class="launch-pack-block">
        <span class="landing-preview-label">Title variations</span>
        <% if (launchPackView?.titles?.length) { %>
          <ul class="launch-pack-list">
            <% launchPackView.titles.forEach((titleOption) => { %>
              <li><%= titleOption %></li>
            <% }) %>
          </ul>
        <% } else { %>
          <p class="mini-note">Generate the Launch Pack to see 2-3 publish-ready title options.</p>
        <% } %>
      </div>

      <div class="launch-pack-block">
        <span class="landing-preview-label">Short description</span>
        <p class="launch-pack-copy">
          <%= launchPackView?.description || 'A concise publish-ready description will appear here once the Launch Pack is generated.' %>
        </p>
      </div>
    </article>

    <div class="launch-pack-locked-grid <%= launchPackFullAccess ? 'is-unlocked' : '' %>">
      <article class="launch-pack-lock-card">
        <div class="launch-pack-lock-head">
          <span class="mini-label"><%= launchPackFullAccess ? 'Unlocked' : 'Locked' %></span>
          <strong>Full Show Notes</strong>
        </div>
        <div class="launch-pack-lock-body">
          <p class="launch-pack-rich-copy"><%= launchPackView?.showNotes || 'Full publish-ready show notes unlock on Pro and Premium.' %></p>
          <% if (!launchPackFullAccess) { %>
            <div class="launch-pack-lock-overlay">
              <p>Upgrade to unlock the full publish-ready notes block for this episode.</p>
            </div>
          <% } %>
        </div>
      </article>

      <article class="launch-pack-lock-card">
        <div class="launch-pack-lock-head">
          <span class="mini-label"><%= launchPackFullAccess ? 'Unlocked' : 'Locked' %></span>
          <strong>Social Captions</strong>
        </div>
        <div class="launch-pack-lock-body">
          <% if (launchPackView?.socialCaptions?.length) { %>
            <ul class="launch-pack-list launch-pack-list-captions">
              <% launchPackView.socialCaptions.forEach((caption) => { %>
                <li><%= caption %></li>
              <% }) %>
            </ul>
          <% } else { %>
            <p class="launch-pack-copy">Three publish-ready social captions unlock on Pro and Premium.</p>
          <% } %>
          <% if (!launchPackFullAccess) { %>
            <div class="launch-pack-lock-overlay">
              <p>Get ready-to-post caption options without leaving the episode workflow.</p>
            </div>
          <% } %>
        </div>
      </article>

      <article class="launch-pack-lock-card">
        <div class="launch-pack-lock-head">
          <span class="mini-label"><%= launchPackFullAccess ? 'Unlocked' : 'Locked' %></span>
          <strong>CTA Script</strong>
        </div>
        <div class="launch-pack-lock-body">
          <p class="launch-pack-rich-copy"><%= launchPackView?.cta || 'A host-read CTA script unlocks on Pro and Premium.' %></p>
          <% if (!launchPackFullAccess) { %>
            <div class="launch-pack-lock-overlay">
              <p>Unlock a stronger close that makes the episode feel ready to publish today.</p>
            </div>
          <% } %>
        </div>
      </article>
    </div>
  </div>

  <% if (launchPackFullAccess && launchPackView?.updatedAt) { %>
    <textarea hidden readonly data-copy-source="launch-pack">LAUNCH PACK

TITLE VARIATIONS
<%= (launchPackView.titles || []).map((titleOption, index) => `${index + 1}. ${titleOption}`).join('\n') %>

SHORT DESCRIPTION
<%= launchPackView.description || '' %>

FULL SHOW NOTES
<%= launchPackView.showNotes || '' %>

SOCIAL CAPTIONS
<%= (launchPackView.socialCaptions || []).map((caption, index) => `${index + 1}. ${caption}`).join('\n\n') %>

CTA SCRIPT
<%= launchPackView.cta || '' %></textarea>
  <% } %>
</section>

<section class="card">
  <div class="section-head">
    <h3>Series Continuity</h3>
    <span class="mini-label">Phase 3</span>
  </div>

  <% if (episodeContinuityContext?.warnings?.length) { %>
    <p><strong>Continuity Checker:</strong> <%= episodeContinuityContext.warnings.join(' · ') %></p>
  <% } else { %>
    <p class="mini-note">No major continuity conflicts detected for this episode right now.</p>
  <% } %>

  <% if (episodeContinuityContext?.callbackSuggestions?.length) { %>
    <p><strong>Callback Planner:</strong> <%= episodeContinuityContext.callbackSuggestions.join(' · ') %></p>
  <% } else { %>
    <p class="mini-note">No callback prompt yet. As the series grows, VicPods will surface more callback opportunities.</p>
  <% } %>

  <% if (episodeContinuityContext?.gapSuggestion) { %>
    <p><strong>Topic Gap Finder:</strong> <%= episodeContinuityContext.gapSuggestion %></p>
  <% } %>
</section>

<section class="card">
  <div class="section-head">
    <h3>Show Notes Pack</h3>
    <span class="mini-label">Launch Assets</span>
  </div>

  <div class="inline-actions">
    <form method="POST" action="/ai/show-notes/generate">
      <input type="hidden" name="seriesId" value="<%= series._id %>" />
      <input type="hidden" name="themeId" value="<%= theme._id %>" />
      <input type="hidden" name="episodeId" value="<%= episode._id %>" />
      <button class="btn btn-primary" type="submit"><%= episode.showNotesPack?.updatedAt ? 'Refresh Show Notes Pack' : 'Generate Show Notes Pack' %></button>
    </form>
    <% if (episode.showNotesPack?.updatedAt) { %>
      <button class="btn btn-ghost" type="button" data-copy-trigger="show-notes-pack" data-copy-label="Copy Show Notes Pack">Copy Show Notes Pack</button>
    <% } %>
  </div>

  <% if (episode.showNotesPack?.updatedAt) { %>
    <p>
      Show Notes Pack ready.
      Last updated: <%= new Date(episode.showNotesPack.updatedAt).toLocaleString() %>
      <% if (episode.showNotesPack?.stale) { %>
        · refresh recommended after recent draft edits
      <% } %>
    </p>

    <% if (episode.showNotesPack.summary) { %>
      <p><strong>Summary:</strong> <%= episode.showNotesPack.summary %></p>
    <% } %>
    <% if (episode.showNotesPack.description) { %>
      <p><strong>Description:</strong> <%= episode.showNotesPack.description %></p>
    <% } %>
    <% if (episode.showNotesPack.keyTakeaways?.length) { %>
      <p><strong>Key Takeaways:</strong> <%= episode.showNotesPack.keyTakeaways.join(' · ') %></p>
    <% } %>
    <% if (episode.showNotesPack.listenerCTA) { %>
      <p><strong>Listener CTA:</strong> <%= episode.showNotesPack.listenerCTA %></p>
    <% } %>
    <% if (episode.showNotesPack.socialPosts?.length) { %>
      <div class="list-stack">
        <% episode.showNotesPack.socialPosts.forEach((post, index) => { %>
          <article class="list-item">
            <div>
              <h4>Social Post <%= index + 1 %></h4>
              <p><%= post %></p>
            </div>
          </article>
        <% }) %>
      </div>
    <% } %>
  <% } else { %>
    <p class="mini-note">Generate a pack with summary, description, key takeaways, CTA, and social-ready copy.</p>
  <% } %>

  <% if (episode.showNotesPack?.updatedAt) { %>
    <textarea hidden readonly data-copy-source="show-notes-pack">SHOW NOTES PACK

SUMMARY
<%= episode.showNotesPack.summary || '' %>

DESCRIPTION
<%= episode.showNotesPack.description || '' %>

KEY TAKEAWAYS
<%= (episode.showNotesPack.keyTakeaways || []).map((takeaway, index) => `${index + 1}. ${takeaway}`).join('\n') %>

LISTENER CTA
<%= episode.showNotesPack.listenerCTA || '' %>

SOCIAL POSTS
<%= (episode.showNotesPack.socialPosts || []).map((post, index) => `Post ${index + 1}: ${post}`).join('\n\n') %></textarea>
  <% } %>
</section>

<section class="card">
  <div class="section-head">
    <h3>Writing Intelligence</h3>
    <span class="mini-label">Phase 2</span>
  </div>

  <div class="inline-actions">
    <form method="POST" action="/ai/hooks/generate">
      <input type="hidden" name="seriesId" value="<%= series._id %>" />
      <input type="hidden" name="themeId" value="<%= theme._id %>" />
      <input type="hidden" name="episodeId" value="<%= episode._id %>" />
      <button class="btn btn-primary" type="submit">Generate Hook Options</button>
    </form>
    <form method="POST" action="/ai/rewrite/section">
      <input type="hidden" name="seriesId" value="<%= series._id %>" />
      <input type="hidden" name="themeId" value="<%= theme._id %>" />
      <input type="hidden" name="episodeId" value="<%= episode._id %>" />
      <input type="hidden" name="section" value="intro" />
      <button class="btn btn-ghost" type="submit">Improve Intro</button>
    </form>
    <form method="POST" action="/ai/rewrite/section">
      <input type="hidden" name="seriesId" value="<%= series._id %>" />
      <input type="hidden" name="themeId" value="<%= theme._id %>" />
      <input type="hidden" name="episodeId" value="<%= episode._id %>" />
      <input type="hidden" name="section" value="body" />
      <button class="btn btn-ghost" type="submit">Tighten Body</button>
    </form>
    <form method="POST" action="/ai/rewrite/section">
      <input type="hidden" name="seriesId" value="<%= series._id %>" />
      <input type="hidden" name="themeId" value="<%= theme._id %>" />
      <input type="hidden" name="episodeId" value="<%= episode._id %>" />
      <input type="hidden" name="section" value="cta" />
      <button class="btn btn-secondary" type="submit">Stronger CTA</button>
    </form>
  </div>

  <% if (episode.scriptDoctor?.overallScore) { %>
    <p>
      <strong>Script Doctor:</strong>
      <%= episode.scriptDoctor.overallScore %>/100 overall
      · clarity <%= episode.scriptDoctor.clarityScore %>
      · pacing <%= episode.scriptDoctor.pacingScore %>
      · repetition <%= episode.scriptDoctor.repetitionScore %>
      · transitions <%= episode.scriptDoctor.transitionScore %>
    </p>
    <% if (episode.scriptDoctor.issues?.length) { %>
      <p><strong>Issues:</strong> <%= episode.scriptDoctor.issues.join(' · ') %></p>
    <% } %>
    <% if (episode.scriptDoctor.strengths?.length) { %>
      <p><strong>Strengths:</strong> <%= episode.scriptDoctor.strengths.join(' · ') %></p>
    <% } %>
    <% if (episode.scriptDoctor.recommendations?.length) { %>
      <p><strong>Recommendations:</strong> <%= episode.scriptDoctor.recommendations.join(' · ') %></p>
    <% } %>
  <% } else { %>
    <p class="mini-note">Save or generate the episode once to calculate the first Script Doctor score.</p>
  <% } %>

  <% if (episode.timeEstimate?.summary) { %>
    <p><strong>Time Estimate:</strong> <%= episode.timeEstimate.summary %></p>
    <% if (episode.timeEstimate.sectionBreakdown?.length) { %>
      <p><strong>Section Breakdown:</strong> <%= episode.timeEstimate.sectionBreakdown.join(' · ') %></p>
    <% } %>
  <% } %>

  <% if (episode.hookOptions?.length) { %>
    <div class="list-stack">
      <% episode.hookOptions.forEach((hookOption) => { %>
        <article class="list-item">
          <div>
            <h4>Hook Option</h4>
            <p><%= hookOption %></p>
          </div>
          <form method="POST" action="/ai/hooks/apply">
            <input type="hidden" name="seriesId" value="<%= series._id %>" />
            <input type="hidden" name="themeId" value="<%= theme._id %>" />
            <input type="hidden" name="episodeId" value="<%= episode._id %>" />
            <input type="hidden" name="hook" value="<%= hookOption %>" />
            <button class="btn btn-ghost" type="submit">Apply Hook</button>
          </form>
        </article>
      <% }) %>
    </div>
  <% } else { %>
    <p class="mini-note">Hook Generator will create multiple opening angles so you can pick the strongest one.</p>
  <% } %>
</section>

<section class="card">
  <div class="section-head">
    <h3>Tone Consistency</h3>
    <span class="mini-label">Tone Engine v1</span>
  </div>

  <% if (showToneScore) { %>
    <p><strong>Score:</strong> <%= Number.isFinite(episode.toneScore) ? `${episode.toneScore}/100` : 'Not scored yet' %></p>
    <% if (episode.toneWarnings && episode.toneWarnings.length) { %>
      <ul class="tone-warnings">
        <% episode.toneWarnings.forEach((warning) => { %>
          <li><%= warning %></li>
        <% }) %>
      </ul>
    <% } else { %>
      <p class="mini-note">No major drift detected.</p>
    <% } %>
  <% } else { %>
    <p class="mini-note">Tone consistency scoring is available on Pro and Premium plans.</p>
    <a href="/settings?section=billing" class="btn btn-ghost">Upgrade</a>
  <% } %>
</section>

<section class="card">
  <div class="section-head">
    <h3>Episode Brief Export</h3>
    <span class="mini-label">TXT · PDF · DOCX</span>
  </div>

  <% const canGenerateBrief = ['Ready', 'Served'].includes(episode.status); %>
  <% const hasTranscript = Boolean(episode.transcript && episode.transcript.trim()); %>

  <% if (!canGenerateBrief) { %>
    <div class="transcript-locked">
      <p><strong>Set this episode to Ready or Served to unlock Episode Brief export.</strong></p>
      <p class="mini-note">Save the episode with status <strong>Ready</strong> or <strong>Served</strong>, then generate and download the brief.</p>
      <div class="inline-actions">
        <button class="btn btn-muted" type="button" disabled>Generate Episode Brief</button>
        <form method="GET" action="/kitchen/<%= series._id %>/themes/<%= theme._id %>/episodes/<%= episode._id %>/transcript/download">
          <select name="format" disabled>
            <option value="pdf">PDF</option>
            <option value="docx">DOCX</option>
            <option value="txt">TXT</option>
          </select>
          <button class="btn btn-muted" type="button" disabled>Download Episode Brief</button>
        </form>
      </div>
    </div>
  <% } else { %>
    <div class="transcript-ready">
      <% if (hasTranscript) { %>
        <p>
          Episode brief ready.
          <% if (episode.transcriptUpdatedAt) { %>
            Last updated: <%= new Date(episode.transcriptUpdatedAt).toLocaleString() %>
          <% } %>
        </p>
      <% } else { %>
        <p>No brief generated yet. Generate once, then export in any format.</p>
      <% } %>

      <p class="mini-note">The brief includes structure, host prompts, close, and any generated show notes summary or takeaways.</p>

      <div class="inline-actions">
        <% if (!hasTranscript) { %>
          <form method="POST" action="/kitchen/<%= series._id %>/themes/<%= theme._id %>/episodes/<%= episode._id %>/transcript/generate">
            <button class="btn btn-primary" type="submit">Generate Episode Brief</button>
          </form>
        <% } %>

        <form method="POST" action="/kitchen/<%= series._id %>/themes/<%= theme._id %>/episodes/<%= episode._id %>/transcript/generate">
          <button class="btn btn-ghost" type="submit">Refresh Episode Brief</button>
        </form>

        <form method="GET" action="/kitchen/<%= series._id %>/themes/<%= theme._id %>/episodes/<%= episode._id %>/transcript/download" class="download-form">
          <select name="format">
            <% (allowedTranscriptFormats || ['txt']).forEach((format) => { %>
              <option value="<%= format %>"><%= format.toUpperCase() %></option>
            <% }) %>
          </select>
          <button class="btn btn-primary" type="submit">Download Episode Brief</button>
        </form>
        <% if (hasTranscript) { %>
          <button class="btn btn-ghost" type="button" data-copy-trigger="episode-brief" data-copy-label="Copy Episode Brief">Copy Episode Brief</button>
        <% } %>
      </div>
      <% if ((allowedTranscriptFormats || ['txt']).length < 3) { %>
        <p class="mini-note">Need more formats? Upgrade in Billing to unlock higher export tiers.</p>
      <% } %>
    </div>
  <% } %>

  <% if (hasTranscript) { %>
    <textarea hidden readonly data-copy-source="episode-brief"><%= episode.transcript %></textarea>
  <% } %>
</section>
