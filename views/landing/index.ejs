<div class="help-page-shell landing-page-shell">
  <section class="landing-hero card" data-help-reveal>
    <div class="landing-copy">
      <span class="landing-kicker"><%= t('page.landing.kicker', 'Ready before you record') %></span>
      <h1><%= t('page.landing.hero.title', 'Go from podcast idea to ready-to-record episode.') %></h1>
      <p class="landing-lead"><%= t('page.landing.hero.body', 'VicPods helps creators turn rough ideas into structured episodes, launch-ready show notes, and episode briefs inside one focused workflow.') %></p>

      <div class="inline-actions landing-actions">
        <% if (currentUser) { %>
          <a href="/create/single" class="btn btn-primary"><%= t('page.landing.cta.primary.user', 'New Episode') %></a>
          <a href="/studio" class="btn btn-secondary"><%= t('page.landing.cta.secondary.user', 'Go to Studio') %></a>
        <% } else { %>
          <a href="#idea-to-episode-generator" class="btn btn-primary"><%= t('page.landing.cta.primary.guest', 'Generate Episode') %></a>
          <a href="#vicpods-pricing" class="btn btn-secondary">View pricing</a>
          <a href="/auth/register" class="btn btn-ghost">Create account</a>
        <% } %>
        <% if (currentUser) { %>
          <a href="/help" class="btn btn-ghost"><%= t('page.landing.cta.help', 'See how it works') %></a>
        <% } else { %>
          <a href="/auth/login" class="btn btn-ghost"><%= t('page.landing.cta.help', 'Sign in') %></a>
        <% } %>
      </div>

      <p class="mini-note">Generate the episode preview first. Create an account only when you want to keep building inside Studio or unlock the full Launch Pack.</p>

      <div class="landing-proof">
        <span class="mini-label"><%= t('page.landing.proof.one', 'Ready-to-record workflow') %></span>
        <span class="mini-label"><%= t('page.landing.proof.two', 'Show notes + episode briefs') %></span>
        <span class="mini-label"><%= t('page.landing.proof.three', 'Series continuity') %></span>
      </div>
    </div>

    <div class="landing-visual">
      <div class="landing-orb landing-orb-back"></div>
      <div class="landing-orb landing-orb-front"></div>
      <div class="landing-model-shell">
        <model-viewer
          src="/models/vicpods-landing-mic.glb"
          camera-controls
          auto-rotate
          rotation-per-second="10deg"
          disable-pan
          shadow-intensity="1"
          exposure="1.05"
          environment-image="neutral"
          interaction-prompt="none"
          touch-action="pan-y"
          style="width: 100%; height: 100%; background: transparent;"
        ></model-viewer>
      </div>
      <div class="landing-wave-ring landing-wave-ring-a"></div>
      <div class="landing-wave-ring landing-wave-ring-b"></div>
      <div class="landing-status-chip"><%= t('page.landing.status', 'March 25 launch') %></div>
    </div>
  </section>

  <section class="card landing-generator-section" id="idea-to-episode-generator" data-help-reveal>
    <div class="landing-generator-head">
      <span class="landing-kicker">Idea to episode generator</span>
      <h2>Paste a podcast idea. See the episode take shape instantly.</h2>
      <p class="landing-generator-copy">
        Generate a live VicPods preview with a stronger title, hook, structure, and CTA before you ever create an account.
      </p>
    </div>

    <form
      class="landing-generator-form"
      action="/api/public/generate"
      method="post"
      data-public-generator-form
    >
      <label class="landing-generator-label" for="landingIdeaInput">Type your podcast idea</label>
      <textarea
        id="landingIdeaInput"
        name="idea"
        class="landing-generator-textarea"
        placeholder="Type your podcast idea..."
        rows="5"
        maxlength="900"
        data-public-generator-input
      ></textarea>

      <div class="landing-generator-actions">
        <div class="landing-generator-meta">
          <span class="mini-label">Instant preview</span>
          <p>No login required. Just paste the idea and generate the episode structure.</p>
        </div>

        <button type="submit" class="btn btn-primary landing-generator-submit" data-public-generator-submit>
          Generate Episode
        </button>
      </div>

      <p
        class="landing-generator-status"
        data-public-generator-status
        hidden
        role="status"
        aria-live="polite"
      ></p>
      <p class="landing-generator-error" data-public-generator-error hidden></p>
    </form>

    <%- include('../partials/landing-episode-preview', {
      unlockHref: currentUser
        ? ((effectivePlan === 'pro' || effectivePlan === 'premium') ? '/studio' : '/settings?section=billing')
        : '/auth/register',
      unlockLabel: currentUser
        ? ((effectivePlan === 'pro' || effectivePlan === 'premium') ? 'Open Studio' : 'Unlock full launch pack')
        : 'Unlock full launch pack',
      fullLaunchPackPreview: Boolean(currentUser && (effectivePlan === 'pro' || effectivePlan === 'premium')),
    }) %>
  </section>

  <section class="card landing-pricing-shell" id="vicpods-pricing" data-help-reveal>
    <div class="section-head landing-pricing-head">
      <div>
        <span class="landing-kicker">Pricing built around momentum</span>
        <h3>Start with the free preview. Upgrade when you want the full launch workflow.</h3>
        <p class="landing-pricing-copy">
          VicPods is designed to prove value early. Generate the episode first, then move into Studio when you want to keep refining, package the launch assets, and publish faster.
        </p>
      </div>
      <div class="landing-pricing-badges">
        <span class="mini-label">Founding pricing through <%= pricing.foundingDeadlineLabel %></span>
        <span class="mini-label">No login needed for the public generator</span>
      </div>
    </div>

    <div class="card-grid premium-plan-grid landing-plan-grid">
      <% publicPricingPlans.forEach((plan) => { %>
        <article class="card premium-plan-card landing-plan-card <%= plan.key === 'pro' ? 'premium-plan-card-featured' : '' %>">
          <div class="premium-plan-card-top">
            <div>
              <span class="mini-label"><%= plan.eyebrow %></span>
              <h4><%= plan.title %></h4>
            </div>
            <% if (plan.key === 'pro') { %>
              <span class="mini-label">Best unlock</span>
            <% } %>
          </div>
          <p class="premium-price"><%= plan.price %></p>
          <p class="premium-plan-tagline"><%= plan.summary %></p>
          <ul class="premium-plan-feature-list">
            <% plan.features.forEach((feature) => { %>
              <li>
                <span class="premium-feature-dot" aria-hidden="true"></span>
                <span><%= feature %></span>
              </li>
            <% }) %>
          </ul>
          <p class="mini-note"><%= plan.note %></p>
        </article>
      <% }) %>
    </div>

    <div class="inline-actions landing-pricing-actions">
      <a href="#idea-to-episode-generator" class="btn btn-primary">Generate Episode</a>
      <% if (currentUser) { %>
        <a href="/settings?section=billing" class="btn btn-secondary">Open Billing</a>
      <% } else { %>
        <a href="/auth/register" class="btn btn-secondary">Create account to keep it</a>
      <% } %>
    </div>
  </section>

  <section class="landing-proof-shell" data-help-reveal>
    <div class="section-head">
      <div>
        <h3>Why creators get value quickly</h3>
        <p class="mini-note">Product proof, not vague promises.</p>
      </div>
      <a href="/examples" class="btn btn-ghost">Open example library</a>
    </div>
    <%- include('../partials/proof-snippet-grid', { proofSnippets: landingProofSnippets }) %>
  </section>

  <section class="landing-examples-shell" data-help-reveal>
    <div class="section-head">
      <div>
        <h3>See the episode structure before you sign up</h3>
        <p class="mini-note">A few example episode directions and Launch Pack previews built in the VicPods style.</p>
      </div>
      <a href="/examples" class="btn btn-ghost">View all examples</a>
    </div>
    <%- include('../partials/example-preview-grid', { examples: featuredExamples, gridClass: 'example-preview-grid-compact' }) %>
  </section>

  <section class="help-story-stack landing-story-stack">
    <article class="card help-story-section" data-help-reveal>
      <div class="help-story-aside">
        <span class="help-story-index">01</span>
        <h3><%= t('page.landing.card.single.title', 'Start a single episode') %></h3>
      </div>
      <div class="help-story-content">
        <p class="help-story-lead"><%= t('page.landing.card.single.body', 'Choose a podcast style, add the topic, and let VicPods generate the structure, hook, and launch direction in one pass.') %></p>
        <div class="inline-actions">
          <a href="/create/single" class="btn btn-ghost"><%= t('page.landing.card.single.cta', 'Open single flow') %></a>
        </div>
      </div>
    </article>

    <article class="card help-story-section" data-help-reveal>
      <div class="help-story-aside">
        <span class="help-story-index">02</span>
        <h3><%= t('page.landing.card.series.title', 'Build a full series') %></h3>
      </div>
      <div class="help-story-content">
        <p class="help-story-lead"><%= t('page.landing.card.series.body', 'Plan season goals, recurring themes, continuity rules, and episode arcs so every recording starts with a clearer brief.') %></p>
        <div class="inline-actions">
          <a href="/create/series" class="btn btn-ghost"><%= t('page.landing.card.series.cta', 'Open series flow') %></a>
        </div>
      </div>
    </article>

    <article class="card help-story-section" data-help-reveal>
      <div class="help-story-aside">
        <span class="help-story-index">03</span>
        <h3><%= t('page.landing.card.guide.title', 'Get guided inside the lab') %></h3>
      </div>
      <div class="help-story-content">
        <p class="help-story-lead"><%= t('page.landing.card.guide.body', 'Use Studio, Workspace, Pantry, and Help Center together to move from draft to launch-ready prep without losing the next step.') %></p>
        <div class="inline-actions">
          <a href="/help" class="btn btn-ghost"><%= t('page.landing.card.guide.cta', 'Open Help Center') %></a>
        </div>
      </div>
    </article>
  </section>

  <section class="card landing-steps landing-steps-shell" data-help-reveal>
    <div class="section-head">
      <h3><%= t('page.landing.steps.title', 'How VicPods gets episodes launch-ready') %></h3>
      <a href="/about" class="btn btn-ghost"><%= t('page.landing.steps.link', 'About VicPods') %></a>
    </div>

    <div class="landing-step-row">
      <article>
        <span class="landing-step-label"><%= t('page.landing.steps.one.label', 'Blueprint') %></span>
        <p><%= t('page.landing.steps.one.body', 'Define audience, transformation, pillars, and voice rules first.') %></p>
      </article>
      <article>
        <span class="landing-step-label"><%= t('page.landing.steps.two.label', 'Structure') %></span>
        <p><%= t('page.landing.steps.two.body', 'Shape the hook, episode flow, CTA, and talking points before drafting.') %></p>
      </article>
      <article>
        <span class="landing-step-label"><%= t('page.landing.steps.three.label', 'Draft') %></span>
        <p><%= t('page.landing.steps.three.body', 'Generate stronger drafts, refine weak sections, and package show notes for launch.') %></p>
      </article>
      <article>
        <span class="landing-step-label"><%= t('page.landing.steps.four.label', 'Release prep') %></span>
        <p><%= t('page.landing.steps.four.body', 'Check readiness, export the episode brief, and record with less prep friction.') %></p>
      </article>
    </div>
  </section>
</div>

<script src="/javascripts/help-center.js" defer></script>
<script src="/javascripts/landing-generator.js" defer></script>
<script type="module" src="https://unpkg.com/@google/model-viewer/dist/model-viewer.min.js"></script>
