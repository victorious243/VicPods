<section class="card" id="onboarding-series-wizard">
  <div class="section-head">
    <h3>Series Wizard</h3>
    <a href="/kitchen" class="btn btn-ghost">Back to Workspace</a>
  </div>

  <div class="wizard-progress" role="list" aria-label="Series mode steps">
    <span class="step active" role="listitem">1. Series Setup</span>
    <span class="step active" role="listitem">2. Series Bible</span>
    <span class="step active" role="listitem">3. Blueprint</span>
    <span class="step active" role="listitem">4. Tone</span>
    <span class="step active" role="listitem">5. Themes</span>
    <span class="step active" role="listitem">6. Episodes</span>
  </div>

  <form
    method="POST"
    action="/create/series"
    class="form-grid"
    id="series-create-form"
    data-ai-loading="true"
    data-ai-loading-guard="generateFirstDraft"
  >
    <section class="wizard-step">
      <h4>Step 1 - Series Setup</h4>
      <label>
        Series Name
        <input id="onboarding-series-name" type="text" name="name" required maxlength="120" placeholder="Creator Growth Blueprint" />
      </label>
      <label>
        Description
        <textarea name="description" rows="2" maxlength="1000" placeholder="What this series helps listeners do"></textarea>
      </label>
      <label>
        Audience Notes
        <input type="text" name="audienceNotes" maxlength="240" placeholder="Who this series is for" />
      </label>
      <label>
        Primary Goal
        <input type="text" name="goal" maxlength="320" placeholder="What success looks like by the end of this series" />
      </label>

      <div class="two-col">
        <label>
          Audience Type
          <select name="audienceType">
            <% audienceTypes.forEach((type) => { %>
              <option value="<%= type %>" <%= type === 'Mixed' ? 'selected' : '' %>><%= type %></option>
            <% }) %>
          </select>
        </label>
        <label>
          Intent
          <select name="intent">
            <% intentOptions.forEach((intent) => { %>
              <option value="<%= intent %>" <%= intent === 'educate' ? 'selected' : '' %>><%= intent %></option>
            <% }) %>
          </select>
        </label>
      </div>

      <label>
        Custom Audience Type (optional)
        <input type="text" name="audienceTypeCustom" maxlength="120" placeholder="Only if Audience Type is Custom" />
      </label>

      <div class="tone-section">
        <div class="section-head">
          <h4>Step 2 - Series Bible</h4>
          <span class="mini-label">Season Planning</span>
        </div>
        <div class="two-col">
          <label>
            Season Goal
            <input type="text" name="seasonGoal" maxlength="320" placeholder="What should this whole season accomplish?" />
          </label>
          <label>
            Audience Promise
            <input type="text" name="audiencePromise" maxlength="240" placeholder="What does every episode promise to deliver?" />
          </label>
        </div>
        <label>
          Recurring Themes
          <textarea name="recurringThemes" rows="3" maxlength="480" placeholder="One recurring theme per line&#10;Positioning&#10;Audience growth&#10;Publishing rhythm"></textarea>
        </label>
      </div>

      <div class="tone-section">
        <div class="section-head">
          <h4>Step 3 - Show Blueprint</h4>
          <span class="mini-label">Structuring App</span>
        </div>
        <div class="two-col">
          <label>
            Audience Problem
            <input type="text" name="audienceProblem" maxlength="240" placeholder="What struggle is this series solving?" />
          </label>
          <label>
            Listener Transformation
            <input type="text" name="listenerTransformation" maxlength="240" placeholder="What will listeners be able to do by the end?" />
          </label>
        </div>
        <label>
          Content Pillars
          <textarea name="contentPillars" rows="3" maxlength="480" placeholder="One pillar per line&#10;Positioning&#10;Episode frameworks&#10;Audience growth"></textarea>
        </label>
        <div class="two-col">
          <label>
            CTA Style
            <select name="ctaStyle">
              <% ctaStyleOptions.forEach((option, index) => { %>
                <option value="<%= option.value %>" <%= index === 0 ? 'selected' : '' %>><%= option.label %></option>
              <% }) %>
            </select>
          </label>
          <label>
            Brand Voice Rules
            <textarea name="brandVoiceRules" rows="3" maxlength="480" placeholder="One rule per line&#10;Be concise&#10;Teach with examples&#10;Avoid vague language"></textarea>
          </label>
        </div>
        <label>
          Banned Words or Phrases
          <textarea name="bannedWords" rows="2" maxlength="240" placeholder="Comma or line separated words to avoid"></textarea>
        </label>
      </div>

      <div class="tone-section">
        <div class="section-head">
          <h4>Step 4 - Tone</h4>
          <span class="mini-label"><%= effectivePlan === 'free' ? 'Free max 3/5' : 'Full intensity unlocked' %></span>
        </div>
        <div class="tone-grid">
          <% tonePresets.forEach((preset, index) => { %>
            <label class="tone-card">
              <input type="radio" name="tonePreset" value="<%= preset.name %>" <%= (index === 7 || (!index && !tonePresets[7])) ? 'checked' : '' %> />
              <span class="tone-card-title"><%= preset.name %></span>
              <span class="tone-card-desc"><%= preset.description %></span>
              <span class="tone-card-example">"<%= preset.exampleHook %>"</span>
            </label>
          <% }) %>
        </div>
        <label>
          Tone Intensity (<span data-range-value="series-create-tone-intensity">3</span>/5)
          <input
            id="series-create-tone-intensity"
            type="range"
            name="toneIntensity"
            min="1"
            max="<%= maxToneIntensity || 3 %>"
            value="3"
            data-range-source="series-create-tone-intensity"
          />
        </label>
      </div>

      <% if (effectivePlan === 'premium') { %>
        <label>
          Voice Persona (Premium)
          <textarea name="voicePersona" rows="2" maxlength="400" data-char-count="series-persona" placeholder="Describe how you speak. Keep it short."></textarea>
          <small class="mini-note"><span data-char-count-label="series-persona">0</span>/400</small>
        </label>
      <% } else { %>
        <label>
          Voice Persona (Premium)
          <textarea rows="2" disabled placeholder="Upgrade to Premium to use a custom persona."></textarea>
          <small class="mini-note">Premium only. <a href="/settings?section=billing">Upgrade</a></small>
        </label>
      <% } %>
    </section>

    <section class="wizard-step">
      <div class="section-head">
        <h4>Step 5 - Themes</h4>
        <% if (canSuggestThemes) { %>
          <button type="button" class="btn btn-secondary" data-suggest-themes>Auto-generate theme suggestions</button>
        <% } else { %>
          <a href="/settings?section=billing" class="btn btn-muted">Auto-generate themes (Pro+)</a>
        <% } %>
      </div>

      <label>
        Theme List (one per line)
        <textarea id="onboarding-series-themes" name="themeNames" rows="5" data-theme-target placeholder="Foundations&#10;Monetization Experiments&#10;Audience Retention"></textarea>
      </label>
    </section>

    <section class="wizard-step">
      <h4>Step 6 - Episodes</h4>
      <label>
        Episodes per Theme (optional)
        <input type="number" name="episodesPerTheme" min="0" max="30" placeholder="e.g. 4" />
      </label>
      <div class="two-col">
        <label>
          Format Template
          <select name="formatTemplate">
            <% formatTemplateOptions.forEach((option, index) => { %>
              <option value="<%= option.value %>" <%= index === 0 ? 'selected' : '' %>><%= option.label %></option>
            <% }) %>
          </select>
        </label>
        <label>
          Hook Style
          <select name="hookStyle">
            <% hookStyleOptions.forEach((option, index) => { %>
              <option value="<%= option.value %>" <%= index === 0 ? 'selected' : '' %>><%= option.label %></option>
            <% }) %>
          </select>
        </label>
      </div>
      <label>
        Default Delivery Style
        <select name="defaultDeliveryStyle">
          <% deliveryStyleOptions.forEach((option) => { %>
            <option value="<%= option.value %>" <%= option.value === 'friendly' ? 'selected' : '' %>><%= option.label %></option>
          <% }) %>
        </select>
      </label>
      <div class="two-col">
        <label>
          Default Episode Type
          <select name="episodeType">
            <% episodeTypeOptions.forEach((option) => { %>
              <option value="<%= option.value %>"><%= option.label %></option>
            <% }) %>
          </select>
        </label>
        <label>
          Duration Preset
          <select name="targetLength">
            <% targetLengthOptions.forEach((option) => { %>
              <option value="<%= option.value %>"><%= option.label %></option>
            <% }) %>
          </select>
        </label>
      </div>
      <label class="check-item">
        <input type="hidden" name="includeFunSegment" value="off" />
        <input type="checkbox" name="includeFunSegment" checked />
        <span>Include fun segment by default</span>
      </label>
      <label class="check-item">
        <input type="checkbox" name="generateFirstDraft" checked />
        <span>Generate Episode 1 draft now</span>
      </label>
      <button id="onboarding-series-create" type="submit" class="btn btn-primary">Create Series Workspace</button>
    </section>
  </form>
</section>
