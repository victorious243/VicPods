<section class="card">
  <div class="section-head">
    <h3>Series Wizard</h3>
    <a href="/create" class="btn btn-ghost">Back to Create</a>
  </div>

  <div class="wizard-progress" role="list" aria-label="Series mode steps">
    <span class="step active" role="listitem">1. Series Setup</span>
    <span class="step active" role="listitem">2. Themes</span>
    <span class="step active" role="listitem">3. Episodes</span>
  </div>

  <form
    method="POST"
    action="/create/series"
    class="form-grid"
    id="series-create-form"
    data-ai-loading="true"
    data-ai-loading-guard="generateFirstDraft"
  >
    <section class="wizard-step">
      <h4>Step 1 - Series Setup</h4>
      <label>
        Series Name
        <input type="text" name="name" required maxlength="120" placeholder="Creator Growth Blueprint" />
      </label>
      <label>
        Description
        <textarea name="description" rows="2" maxlength="1000" placeholder="What this series helps listeners do"></textarea>
      </label>
      <label>
        Audience Notes
        <input type="text" name="audienceNotes" maxlength="240" placeholder="Who this series is for" />
      </label>
      <label>
        Primary Goal
        <input type="text" name="goal" maxlength="320" placeholder="What success looks like by the end of this series" />
      </label>

      <div class="two-col">
        <label>
          Audience Type
          <select name="audienceType">
            <% audienceTypes.forEach((type) => { %>
              <option value="<%= type %>" <%= type === 'Mixed' ? 'selected' : '' %>><%= type %></option>
            <% }) %>
          </select>
        </label>
        <label>
          Intent
          <select name="intent">
            <% intentOptions.forEach((intent) => { %>
              <option value="<%= intent %>" <%= intent === 'educate' ? 'selected' : '' %>><%= intent %></option>
            <% }) %>
          </select>
        </label>
      </div>

      <label>
        Custom Audience Type (optional)
        <input type="text" name="audienceTypeCustom" maxlength="120" placeholder="Only if Audience Type is Custom" />
      </label>

      <div class="tone-section">
        <div class="section-head">
          <h4>Tone</h4>
          <span class="mini-label"><%= effectivePlan === 'free' ? 'Free max 3/5' : 'Full intensity unlocked' %></span>
        </div>
        <div class="tone-grid">
          <% tonePresets.forEach((preset, index) => { %>
            <label class="tone-card">
              <input type="radio" name="tonePreset" value="<%= preset.name %>" <%= (index === 7 || (!index && !tonePresets[7])) ? 'checked' : '' %> />
              <span class="tone-card-title"><%= preset.name %></span>
              <span class="tone-card-desc"><%= preset.description %></span>
              <span class="tone-card-example">"<%= preset.exampleHook %>"</span>
            </label>
          <% }) %>
        </div>
        <label>
          Tone Intensity (<span data-range-value="series-create-tone-intensity">3</span>/5)
          <input
            id="series-create-tone-intensity"
            type="range"
            name="toneIntensity"
            min="1"
            max="<%= maxToneIntensity || 3 %>"
            value="3"
            data-range-source="series-create-tone-intensity"
          />
        </label>
      </div>

      <% if (effectivePlan === 'premium') { %>
        <label>
          Voice Persona (Premium)
          <textarea name="voicePersona" rows="2" maxlength="400" data-char-count="series-persona" placeholder="Describe how you speak. Keep it short."></textarea>
          <small class="mini-note"><span data-char-count-label="series-persona">0</span>/400</small>
        </label>
      <% } else { %>
        <label>
          Voice Persona (Premium)
          <textarea rows="2" disabled placeholder="Upgrade to Premium to use a custom persona."></textarea>
          <small class="mini-note">Premium only. <a href="/settings?section=billing">Upgrade</a></small>
        </label>
      <% } %>
    </section>

    <section class="wizard-step">
      <div class="section-head">
        <h4>Step 2 - Themes</h4>
        <% if (canSuggestThemes) { %>
          <button type="button" class="btn btn-secondary" data-suggest-themes>Auto-generate theme suggestions</button>
        <% } else { %>
          <a href="/settings?section=billing" class="btn btn-muted">Auto-generate themes (Pro+)</a>
        <% } %>
      </div>

      <label>
        Theme List (one per line)
        <textarea name="themeNames" rows="5" data-theme-target placeholder="Foundations&#10;Monetization Experiments&#10;Audience Retention"></textarea>
      </label>
    </section>

    <section class="wizard-step">
      <h4>Step 3 - Episodes</h4>
      <label>
        Episodes per Theme (optional)
        <input type="number" name="episodesPerTheme" min="0" max="30" placeholder="e.g. 4" />
      </label>
      <div class="two-col">
        <label>
          Default Episode Type
          <select name="episodeType">
            <option value="solo">Solo</option>
            <option value="interview">Interview</option>
          </select>
        </label>
        <label>
          Default Target Length
          <select name="targetLength">
            <option value="">Flexible</option>
            <option value="10-15">10-15 min</option>
            <option value="20-30">20-30 min</option>
            <option value="45+">45+ min</option>
          </select>
        </label>
      </div>
      <label class="check-item">
        <input type="checkbox" name="includeFunSegment" checked />
        <span>Include fun segment by default</span>
      </label>
      <label class="check-item">
        <input type="checkbox" name="generateFirstDraft" checked />
        <span>Generate Episode 1 draft now</span>
      </label>
      <button type="submit" class="btn btn-primary">Create Series Workspace</button>
    </section>
  </form>
</section>
