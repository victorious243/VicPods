<section class="auth-card">
  <h3>Create account</h3>
  <p>Build your podcast workflow from one clean dashboard.</p>
  <% if (googleAuthEnabled) { %>
    <a href="/auth/google/signup" class="btn btn-google">
      <span class="google-mark" aria-hidden="true">
        <svg viewBox="0 0 24 24" role="img" focusable="false">
          <path fill="#EA4335" d="M12 10.2v3.9h5.5c-.2 1.3-1.5 3.9-5.5 3.9-3.3 0-6-2.7-6-6s2.7-6 6-6c1.9 0 3.2.8 3.9 1.5l2.7-2.6C16.9 3.4 14.7 2.5 12 2.5 6.9 2.5 2.8 6.6 2.8 11.7S6.9 20.9 12 20.9c6.9 0 9.2-4.8 9.2-7.3 0-.5-.1-.9-.1-1.3H12z" />
        </svg>
      </span>
      <span>Continue with Google</span>
    </a>
    <p class="mini-note">By continuing, you agree to the <a href="/auth/terms" target="_blank" rel="noopener">Terms and Conditions</a>.</p>
  <% } else { %>
    <button type="button" class="btn btn-google" disabled>
      <span class="google-mark" aria-hidden="true">
        <svg viewBox="0 0 24 24" role="img" focusable="false">
          <path fill="#EA4335" d="M12 10.2v3.9h5.5c-.2 1.3-1.5 3.9-5.5 3.9-3.3 0-6-2.7-6-6s2.7-6 6-6c1.9 0 3.2.8 3.9 1.5l2.7-2.6C16.9 3.4 14.7 2.5 12 2.5 6.9 2.5 2.8 6.6 2.8 11.7S6.9 20.9 12 20.9c6.9 0 9.2-4.8 9.2-7.3 0-.5-.1-.9-.1-1.3H12z" />
        </svg>
      </span>
      <span>Google Sign Up Unavailable</span>
    </button>
    <p class="mini-note">
      Missing env vars:
      <%= (googleAuthMissing && googleAuthMissing.length) ? googleAuthMissing.join(', ') : 'configuration required' %>
    </p>
  <% } %>

  <div class="auth-separator" role="presentation">
    <span>or sign up with email</span>
  </div>

  <form method="POST" action="/auth/register" class="form-grid">
    <label>
      Name
      <input type="text" name="name" required maxlength="80" placeholder="Your name" />
    </label>
    <label>
      Email
      <input type="email" name="email" required placeholder="you@example.com" />
    </label>
    <label>
      Password
      <input type="password" name="password" required minlength="8" placeholder="At least 8 characters" />
    </label>
    <label class="check-item">
      <input type="checkbox" name="acceptTerms" required />
      <span>
        I agree to the <a href="/auth/terms" target="_blank" rel="noopener">Terms and Conditions</a>.
      </span>
    </label>
    <button type="submit" class="btn btn-primary">Create Workspace</button>
  </form>
  <p class="auth-foot">Already have an account? <a href="/auth/login">Sign in</a></p>
</section>
