<section class="auth-experience">
  <%- include('../partials/auth-scene', {
    kicker: 'Secure studio access',
    heading: 'Return to your podcast command center.',
    body: 'Sign back in to continue drafting episodes, refining launch packs, and moving your workflow toward ready-to-record.',
    featureChips: ['Protected sign-in', 'Studio + Kitchen + Pantry', 'Launch prep synced'],
    metricCards: [
      { value: 'Email PIN + Google', label: 'Trusted entry options' },
      { value: 'Drafts stay in place', label: 'Series, episodes, and billing stay synced' },
      { value: 'Built for creators', label: 'One clean system from idea to launch' }
    ],
    railItems: [
      { title: 'Enter your Studio', body: 'Resume the exact episode workflow you left behind.' },
      { title: 'Confirm when needed', body: 'New sign-ins can trigger a quick verification step.' },
      { title: 'Keep momentum', body: 'Open drafts, launch packs, and planning assets instantly.' }
    ]
  }) %>

  <section class="auth-panel">
    <div class="auth-panel-header">
      <span class="auth-panel-eyebrow">Sign in to VicPods</span>
      <h1><%= pageTitle || 'Welcome back to VicPods' %></h1>
      <p><%= subtitle || 'Sign in to enter your Studio.' %> New accounts may require a short security confirmation before access is granted.</p>
    </div>

    <div class="auth-panel-stack">
      <% if (googleAuthEnabled) { %>
        <a href="/auth/google/login" class="btn btn-google auth-social-btn">
          <span class="google-mark" aria-hidden="true">
            <svg viewBox="0 0 24 24" role="img" focusable="false">
              <path fill="#EA4335" d="M12 10.2v3.9h5.5c-.2 1.3-1.5 3.9-5.5 3.9-3.3 0-6-2.7-6-6s2.7-6 6-6c1.9 0 3.2.8 3.9 1.5l2.7-2.6C16.9 3.4 14.7 2.5 12 2.5 6.9 2.5 2.8 6.6 2.8 11.7S6.9 20.9 12 20.9c6.9 0 9.2-4.8 9.2-7.3 0-.5-.1-.9-.1-1.3H12z" />
            </svg>
          </span>
          <span>Continue with Google</span>
        </a>
      <% } else { %>
        <button type="button" class="btn btn-google auth-social-btn" disabled>
          <span class="google-mark" aria-hidden="true">
            <svg viewBox="0 0 24 24" role="img" focusable="false">
              <path fill="#EA4335" d="M12 10.2v3.9h5.5c-.2 1.3-1.5 3.9-5.5 3.9-3.3 0-6-2.7-6-6s2.7-6 6-6c1.9 0 3.2.8 3.9 1.5l2.7-2.6C16.9 3.4 14.7 2.5 12 2.5 6.9 2.5 2.8 6.6 2.8 11.7S6.9 20.9 12 20.9c6.9 0 9.2-4.8 9.2-7.3 0-.5-.1-.9-.1-1.3H12z" />
            </svg>
          </span>
          <span>Google auth not configured</span>
        </button>
        <p class="mini-note auth-inline-note">
          Missing env vars:
          <%= (googleAuthMissing && googleAuthMissing.length) ? googleAuthMissing.join(', ') : 'configuration required' %>
        </p>
      <% } %>

      <div class="auth-separator" role="presentation">
        <span>or sign in with email</span>
      </div>

      <form method="POST" action="/auth/login" class="form-grid auth-form">
        <label>
          Email
          <input type="email" name="email" required placeholder="you@example.com" autocomplete="email" />
        </label>
        <label>
          Password
          <input type="password" name="password" required placeholder="Enter your password" autocomplete="current-password" />
        </label>
        <button type="submit" class="btn btn-primary auth-submit-btn">Enter Studio</button>
      </form>
    </div>

    <div class="auth-support-grid">
      <section class="auth-support-card">
        <span class="auth-support-label">Need to verify your email?</span>
        <p>Enter your account email and continue with the PIN you received from VicPods.</p>
        <form method="GET" action="/auth/verify" class="form-grid auth-inline-form">
          <label>
            Account email
            <input type="email" name="email" required placeholder="you@example.com" />
          </label>
          <button type="submit" class="btn btn-secondary">Enter verification PIN</button>
        </form>
      </section>

      <section class="auth-support-card auth-support-card-soft">
        <span class="auth-support-label">Locked out?</span>
        <p>Password resets stay secure and only take a minute. Your draft history and billing remain untouched.</p>
        <div class="auth-link-row">
          <a href="/auth/forgot-password" class="btn btn-ghost">Reset password</a>
          <a href="/about" class="auth-text-link"><%= t('page.about.link', 'About VicPods') %></a>
        </div>
      </section>
    </div>

    <p class="auth-foot auth-foot-premium">No account yet? <a href="/auth/register">Create one</a></p>
  </section>
</section>
