<section class="auth-card">
  <h3>Login</h3>
  <p>Step into your Studio. New accounts require a quick email security code at sign-in.</p>
  <% if (googleAuthEnabled) { %>
    <a href="/auth/google/login" class="btn btn-google">
      <span class="google-mark" aria-hidden="true">
        <svg viewBox="0 0 24 24" role="img" focusable="false">
          <path fill="#EA4335" d="M12 10.2v3.9h5.5c-.2 1.3-1.5 3.9-5.5 3.9-3.3 0-6-2.7-6-6s2.7-6 6-6c1.9 0 3.2.8 3.9 1.5l2.7-2.6C16.9 3.4 14.7 2.5 12 2.5 6.9 2.5 2.8 6.6 2.8 11.7S6.9 20.9 12 20.9c6.9 0 9.2-4.8 9.2-7.3 0-.5-.1-.9-.1-1.3H12z" />
        </svg>
      </span>
      <span>Continue with Google</span>
    </a>
  <% } else { %>
    <button type="button" class="btn btn-google" disabled>
      <span class="google-mark" aria-hidden="true">
        <svg viewBox="0 0 24 24" role="img" focusable="false">
          <path fill="#EA4335" d="M12 10.2v3.9h5.5c-.2 1.3-1.5 3.9-5.5 3.9-3.3 0-6-2.7-6-6s2.7-6 6-6c1.9 0 3.2.8 3.9 1.5l2.7-2.6C16.9 3.4 14.7 2.5 12 2.5 6.9 2.5 2.8 6.6 2.8 11.7S6.9 20.9 12 20.9c6.9 0 9.2-4.8 9.2-7.3 0-.5-.1-.9-.1-1.3H12z" />
        </svg>
      </span>
      <span>Google Auth Not Configured</span>
    </button>
    <p class="mini-note">
      Missing env vars:
      <%= (googleAuthMissing && googleAuthMissing.length) ? googleAuthMissing.join(', ') : 'configuration required' %>
    </p>
  <% } %>
  <form method="POST" action="/auth/login" class="form-grid">
    <label>
      Email
      <input type="email" name="email" required placeholder="you@example.com" />
    </label>
    <label>
      Password
      <input type="password" name="password" required placeholder="Minimum 8 characters" />
    </label>
    <button type="submit" class="btn btn-primary">Sign In</button>
  </form>
  <form method="GET" action="/auth/verify" class="form-grid">
    <label>
      Need to verify your email?
      <input type="email" name="email" required placeholder="Enter your account email" />
    </label>
    <button type="submit" class="btn btn-ghost">Enter verification PIN</button>
  </form>
  <p class="auth-foot">Forgot your password? <a href="/auth/forgot-password">Reset it</a></p>
  <p class="auth-foot">No account yet? <a href="/auth/register">Create one</a> · <a href="/about"><%= t('page.about.link', 'About VicPods') %></a></p>
</section>
