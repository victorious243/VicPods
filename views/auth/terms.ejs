<%
  const clauses = [
    {
      title: 'Service Scope',
      body: 'VicPods is an AI-powered podcast planning and production workspace. We provide tools for episode drafting, continuity planning, tone control, episode brief generation, and export workflows.',
    },
    {
      title: 'Accounts and Eligibility',
      body: 'You are responsible for your account activity and credentials. You must provide accurate registration details and keep your login information secure.',
    },
    {
      title: 'Verification and Communications',
      body: 'To activate a new account, you must verify your email with a one-time PIN. You consent to receiving service emails related to verification, billing, and account security.',
    },
    {
      title: 'Subscription and Billing',
      body: 'Paid plans renew according to your Stripe subscription terms unless canceled. Plan access depends on active payment status and may downgrade to Free when a subscription expires, is canceled, or is unpaid.',
    },
    {
      title: 'AI-Generated Content',
      body: 'AI output is assistive and may require review and editing for accuracy, compliance, and brand fit. You are responsible for the final content you publish and record.',
    },
    {
      title: 'Acceptable Use',
      body: 'You may not use VicPods for unlawful activity, credential abuse, payment fraud, malware distribution, or content that violates intellectual property rights or applicable platform policies.',
    },
    {
      title: 'Data and Privacy',
      body: 'We store account data and production content to operate the service. You retain ownership of your podcast content. We process data needed for authentication, billing, and product functionality.',
    },
    {
      title: 'Service Availability',
      body: 'We aim for reliable uptime but do not guarantee uninterrupted service. We may update features, usage limits, and plan capabilities as the product evolves.',
    },
    {
      title: 'Limitation of Liability',
      body: 'VicPods is provided on an “as is” basis to the extent permitted by law. We are not liable for indirect or consequential damages resulting from the use of the platform.',
    },
    {
      title: 'Changes to Terms',
      body: 'We may update these terms when features, billing policies, or legal requirements change. Continued use of the service after updates means you accept the revised terms.',
    }
  ];
%>

<section class="terms-experience">
  <header class="terms-hero">
    <div class="terms-hero-copy">
      <span class="auth-kicker">Trust, billing, and usage</span>
      <h1><%= pageTitle || 'VicPods Terms and Conditions' %></h1>
      <p><%= subtitle || 'Rules, responsibilities, and subscription terms for using VicPods.' %></p>
    </div>

    <div class="chip-wrap terms-chip-wrap">
      <span class="chip auth-chip">Effective date: February 25, 2026</span>
      <span class="chip auth-chip">Applies to all VicPods accounts</span>
      <span class="chip auth-chip">Billing processed with Stripe</span>
    </div>
  </header>

  <div class="terms-layout">
    <aside class="terms-sidebar">
      <section class="terms-side-card">
        <h2>What these terms cover</h2>
        <ul class="terms-side-list">
          <li>Account security and eligibility</li>
          <li>Plan renewals, payment status, and downgrades</li>
          <li>Ownership and use of your podcast content</li>
          <li>How VicPods handles AI-assisted output</li>
          <li>Acceptable use, liability, and future updates</li>
        </ul>
      </section>

      <section class="terms-side-card terms-side-card-accent">
        <h2>Quick summary</h2>
        <p>VicPods helps creators structure episodes and launch prep. You keep responsibility for what you publish, and paid access depends on an active subscription.</p>
        <div class="auth-link-row terms-link-row">
          <a href="/auth/register" class="btn btn-primary">Create account</a>
          <a href="/about" class="btn btn-ghost"><%= t('page.about.link', 'About VicPods') %></a>
        </div>
      </section>
    </aside>

    <div class="terms-document">
      <% clauses.forEach(function(clause, index) { %>
        <article class="terms-clause-card">
          <div class="terms-clause-index"><%= String(index + 1).padStart(2, '0') %></div>
          <div class="terms-clause-copy">
            <h3><%= clause.title %></h3>
            <p><%= clause.body %></p>
          </div>
        </article>
      <% }) %>
    </div>
  </div>
</section>
