<section class="auth-card">
  <h3>Reset your password</h3>
  <p>Enter your account email and we will send you a secure reset link if the account exists.</p>

  <form method="POST" action="/auth/forgot-password" class="form-grid">
    <label>
      Email
      <input
        type="email"
        name="email"
        required
        placeholder="you@example.com"
        value="<%= email || '' %>"
      />
    </label>
    <button type="submit" class="btn btn-primary">Send Reset Link</button>
  </form>

  <p class="mini-note">For security, we do not confirm whether an email address is registered.</p>
  <p class="auth-foot"><a href="/auth/login">Back to sign in</a></p>
</section>
